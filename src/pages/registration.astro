---
// src/pages/registration.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Join visha — Get Early Access"
  description="Sign up for early access to visha. Be first to buy and sell pre-loved fashion in Nairobi with M-Pesa payments."
  canonical="https://visha.app/registration"
>

  <div class="reg-wrap">
    <div class="reg-card">

      <!-- Left panel -->
      <div class="reg-panel">
        <a href="/" class="reg-logo" aria-label="Back to visha home">
          <div class="reg-logo-mark">
            <span class="material-symbols-outlined">local_mall</span>
          </div>
          <div>
            <span class="reg-logo-text">visha</span>
            <span class="reg-logo-sub">for the collective</span>
          </div>
        </a>

        <div>
          <h1 class="reg-title">Join the<br />Inner Circle</h1>
          <p class="reg-subtitle">Get early access to Kenya's premier thrift app. M-Pesa drops, community events, and founding member perks.</p>
        </div>

        <ul class="perks">
          <li class="perk">
            <span class="perk-check material-symbols-outlined">check</span>
            M-Pesa payments built in
          </li>
          <li class="perk">
            <span class="perk-check material-symbols-outlined">check</span>
            Verified seller badge on your profile
          </li>
          <li class="perk">
            <span class="perk-check material-symbols-outlined">check</span>
            Access to Nairobi community events
          </li>
          <li class="perk">
            <span class="perk-check material-symbols-outlined">check</span>
            Founding member badge — exclusive to early signups
          </li>
        </ul>

        <div class="reg-lock">
          <span class="material-symbols-outlined" style="font-size:16px">lock</span>
          Early access — first come, first served.
        </div>
      </div>

      <!-- Right panel: form -->
      <div class="reg-form-panel">

        <div id="form-container">
          <h2 class="form-title">Create your account</h2>
          <p class="form-subtitle">Free forever. No credit card needed.</p>

          <form id="reg-form" class="reg-form" novalidate>

            <div class="field">
              <label for="full-name" class="field-label">Full Name</label>
              <div class="field-input-wrap">
                <span class="field-icon material-symbols-outlined">person</span>
                <input id="full-name" type="text" name="fullName" autocomplete="name" placeholder="Your full name" required class="input field-input" />
              </div>
            </div>

            <div class="field">
              <label for="phone" class="field-label">Phone (M-Pesa)</label>
              <div class="field-input-wrap">
                <span class="field-icon material-symbols-outlined">phone_android</span>
                <input id="phone" type="tel" name="phone" autocomplete="tel" placeholder="e.g. 0712 345 678" required class="input field-input" />
              </div>
            </div>

            <div class="field">
              <label for="email" class="field-label">Email Address</label>
              <div class="field-input-wrap">
                <span class="field-icon material-symbols-outlined">alternate_email</span>
                <input id="email" type="email" name="email" autocomplete="email" placeholder="email@example.com" required class="input field-input" />
              </div>
            </div>

            <div class="field">
              <label for="style" class="field-label">Your Style</label>
              <div class="field-input-wrap">
                <span class="field-icon material-symbols-outlined">style</span>
                <select id="style" name="style" class="input field-input field-select">
                  <option value="" disabled selected>Select your vibe</option>
                  <option value="minimal">Minimalist &amp; Clean</option>
                  <option value="streetwear">Streetwear &amp; Bold</option>
                  <option value="luxury">Luxury &amp; Classic</option>
                  <option value="vibrant">Vibrant &amp; Artistic</option>
                </select>
                <span class="field-icon field-icon--right material-symbols-outlined">expand_more</span>
              </div>
            </div>

            <button type="submit" class="btn btn-primary submit-btn">
              Secure My Spot
              <span class="material-symbols-outlined" style="font-size:18px">arrow_forward</span>
            </button>

          </form>

          <p class="form-terms">
            By registering you agree to our
            <a href="#">Terms</a> and <a href="#">Privacy Policy</a>.
          </p>
        </div>

        <!-- Success state -->
        <div id="success-msg" class="success hidden">
          <div class="success-icon">
            <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1; font-size:2rem">check_circle</span>
          </div>
          <h2 class="success-title">You're on the list!</h2>
          <p class="success-body">We'll send your early access details to your phone and email as soon as visha launches.</p>
          <a href="/" class="btn btn-ghost">Back to home</a>
        </div>

      </div>
    </div>
  </div>

</Layout>

<script>
  document.getElementById('reg-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    document.getElementById('form-container')!.classList.add('hidden');
    document.getElementById('success-msg')!.classList.remove('hidden');
  });
</script>

<style>
  .reg-wrap {
    min-height: calc(100vh - 60px);
    display: flex; align-items: center; justify-content: center;
    padding: 2rem var(--px-mobile);
    background: var(--alabaster);
  }
  body.dark .reg-wrap { background: var(--charcoal-soft); }

  .reg-card {
    width: 100%; max-width: 56rem;
    display: grid;
    border: 2px solid var(--charcoal);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  @media (min-width: 1024px) { .reg-card { grid-template-columns: 1fr 1fr; } }

  /* Left panel */
  .reg-panel {
    background: var(--charcoal);
    padding: 2.5rem;
    display: flex; flex-direction: column; gap: 2rem;
    color: var(--alabaster);
  }

  .reg-logo {
    display: inline-flex; align-items: center; gap: 0.625rem;
  }
  .reg-logo-mark {
    width: 2.25rem; height: 2.25rem;
    background: var(--garnet); border: 2px solid rgba(230,225,222,0.3);
    display: flex; align-items: center; justify-content: center; color: var(--white);
  }
  .reg-logo-mark .material-symbols-outlined { font-size: 16px; }
  .reg-logo-text { font-family: var(--font-display); font-weight: 800; font-size: 1.125rem; display: block; }
  .reg-logo-sub  { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(230,225,222,0.5); display: block; }

  .reg-title    { font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 800; line-height: 1.1; margin-bottom: 0.75rem; }
  .reg-subtitle { font-size: 0.9375rem; color: rgba(230,225,222,0.7); line-height: 1.65; }

  .perks { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
  .perk  { display: flex; align-items: center; gap: 0.75rem; font-size: 0.875rem; color: rgba(230,225,222,0.9); }
  .perk-check {
    width: 1.625rem; height: 1.625rem;
    background: var(--garnet); border: 1px solid rgba(230,225,222,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: var(--white); flex-shrink: 0;
  }

  .reg-lock {
    margin-top: auto;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(230,225,222,0.15);
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8125rem; color: rgba(230,225,222,0.55);
  }
  .reg-lock .material-symbols-outlined { font-size: 16px; }

  /* Right panel */
  .reg-form-panel {
    background: var(--white);
    padding: 2.5rem;
  }
  body.dark .reg-form-panel { background: var(--color-surface-card-dark); }

  .form-title    { font-family: var(--font-display); font-size: 1.5rem; font-weight: 800; color: var(--charcoal); margin-bottom: 0.25rem; }
  body.dark .form-title { color: var(--alabaster); }
  .form-subtitle { font-size: 0.875rem; color: var(--color-ink-muted); margin-bottom: 2rem; }
  body.dark .form-subtitle { color: var(--color-ink-muted-dark); }

  .reg-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field-label { font-size: 0.6875rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--charcoal); }
  body.dark .field-label { color: var(--alabaster); }

  .field-input-wrap { position: relative; }
  .field-icon {
    position: absolute; left: 0.875rem; top: 50%; transform: translateY(-50%);
    font-size: 16px; color: var(--color-ink-muted); pointer-events: none;
  }
  .field-icon--right { left: auto; right: 0.875rem; }
  .field-input { padding-left: 2.75rem !important; }
  .field-select { appearance: none; padding-right: 2.75rem !important; cursor: pointer; }

  .submit-btn { width: 100%; justify-content: center; margin-top: 0.5rem; font-size: 0.9375rem; padding-block: 1rem; }

  .form-terms { font-size: 0.75rem; text-align: center; color: var(--color-ink-muted); margin-top: 1rem; }
  body.dark .form-terms { color: var(--color-ink-muted-dark); }
  .form-terms a { font-weight: 700; color: var(--charcoal); }
  body.dark .form-terms a { color: var(--alabaster); }
  .form-terms a:hover { color: var(--garnet); }

  /* Success */
  .success { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1rem; padding-block: 3rem; }
  .success.hidden { display: none; }
  #form-container.hidden { display: none; }

  .success-icon {
    width: 4rem; height: 4rem;
    background: var(--garnet); border: 2px solid var(--charcoal);
    display: flex; align-items: center; justify-content: center; color: var(--white);
    box-shadow: var(--shadow-sm);
  }
  .success-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 800; color: var(--charcoal); }
  body.dark .success-title { color: var(--alabaster); }
  .success-body  { font-size: 0.875rem; color: var(--color-ink-muted); max-width: 28ch; line-height: 1.6; }
  body.dark .success-body { color: var(--color-ink-muted-dark); }
</style>
