<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Join gikomba.app — Get Early Access</title>
  <meta name="description" content="Sign up for early access to gikomba.app. Be first to buy and sell pre-loved fashion in Nairobi with M-Pesa payments." />
  <meta property="og:title" content="Join gikomba.app — Get Early Access" />
  <meta property="og:type" content="website" />
  <link rel="canonical" href="https://gikomba.app/registration.html" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles.css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: { extend: { colors: { primary:"#B5F03A", secondary:"#7B4FC4", accent:"#007A91", ink:"#111111", "ink-muted":"#555555", "ink-dark":"#E8E8E8", "ink-muted-dark":"#9CA3AF" }, fontFamily: { display:["'Syne'","sans-serif"], body:["'DM Sans'","sans-serif"] }, borderRadius: { DEFAULT:"0px", none:"0px", sm:"0px", md:"0px", lg:"0px", xl:"0px", "2xl":"0px", full:"0px" } } }
    };
  </script>
  <style>
    body { font-family: 'DM Sans', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Syne', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
  </style>
</head>

<body class="bg-[#F5F4F0] dark:bg-[#0F0F0F] text-ink dark:text-ink-dark antialiased transition-colors duration-200 min-h-screen flex flex-col">

  <div id="site-nav"></div>

  <main class="flex-1 flex flex-col items-center justify-center px-4 py-12 sm:py-16">

    <!-- Side-by-side on desktop, stacked on mobile -->
    <div class="w-full max-w-4xl grid lg:grid-cols-2 gap-0 border-2 border-ink dark:border-[#444] overflow-hidden" style="box-shadow:8px 8px 0 #111">

      <!-- Left: App pitch panel -->
      <div class="bg-secondary p-8 sm:p-10 flex flex-col gap-6 text-white">
        <a href="index.html" class="flex items-center gap-2 w-fit" aria-label="Back to gikomba.app home">
          <div class="w-8 h-8 bg-primary border-2 border-white/30 flex items-center justify-center">
            <span class="material-symbols-outlined text-ink" style="font-size:16px">local_mall</span>
          </div>
          <span style="font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;">gikomba<span style="color:#B5F03A">.app</span></span>
        </a>

        <div>
          <h1 class="font-display text-3xl sm:text-4xl font-extrabold leading-tight mb-3">
            Join the Inner Circle
          </h1>
          <p class="text-white/75 text-base leading-relaxed">
            Get early access to Kenya's premier thrift app. M-Pesa drops, exclusive community events, and founding member perks.
          </p>
        </div>

        <!-- App perks -->
        <ul class="flex flex-col gap-3 text-sm">
          <li class="flex items-center gap-3">
            <span class="w-7 h-7 bg-primary border border-white/20 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-ink" style="font-size:14px">check</span>
            </span>
            <span class="text-white/90">M-Pesa payments built in</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-7 h-7 bg-primary border border-white/20 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-ink" style="font-size:14px">check</span>
            </span>
            <span class="text-white/90">Verified seller badge on your profile</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-7 h-7 bg-primary border border-white/20 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-ink" style="font-size:14px">check</span>
            </span>
            <span class="text-white/90">Access to Nairobi community events</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="w-7 h-7 bg-primary border border-white/20 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-ink" style="font-size:14px">check</span>
            </span>
            <span class="text-white/90">Founding member badge — exclusive to early signups</span>
          </li>
        </ul>

        <!-- Waitlist note -->
        <div class="mt-auto border-t border-white/20 pt-5 flex items-center gap-3">
          <div class="w-8 h-8 bg-primary border border-white/20 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-ink" style="font-size:16px">lock</span>
          </div>
          <p class="text-sm text-white/70">Early access — first come, first served.</p>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-white dark:bg-[#1A1A1A] p-8 sm:p-10">

        <div id="form-container">
          <h2 class="font-display text-2xl font-extrabold text-ink dark:text-ink-dark mb-1">Create your account</h2>
          <p class="text-ink-muted dark:text-ink-muted-dark text-sm mb-7">Free forever. No credit card needed.</p>

          <form class="flex flex-col gap-5" onsubmit="handleSubmit(event)" novalidate>

            <div class="flex flex-col gap-1.5">
              <label for="full-name" class="text-xs font-black uppercase tracking-widest text-ink dark:text-ink-dark">Full Name</label>
              <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-ink-muted" style="font-size:16px">person</span>
                <input id="full-name" type="text" name="fullName" autocomplete="name" placeholder="Your full name" required
                  class="w-full border-2 border-ink dark:border-[#444] bg-white dark:bg-[#111] text-ink dark:text-ink-dark py-3.5 pl-10 pr-4 focus:outline-none focus:border-accent transition-colors placeholder:text-ink-muted text-sm" />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="phone" class="text-xs font-black uppercase tracking-widest text-ink dark:text-ink-dark">Phone (M-Pesa)</label>
              <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-ink-muted" style="font-size:16px">phone_iphone</span>
                <input id="phone" type="tel" name="phone" autocomplete="tel" placeholder="e.g. 0712 345 678" required
                  class="w-full border-2 border-ink dark:border-[#444] bg-white dark:bg-[#111] text-ink dark:text-ink-dark py-3.5 pl-10 pr-4 focus:outline-none focus:border-accent transition-colors placeholder:text-ink-muted text-sm" />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-xs font-black uppercase tracking-widest text-ink dark:text-ink-dark">Email Address</label>
              <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-ink-muted" style="font-size:16px">alternate_email</span>
                <input id="email" type="email" name="email" autocomplete="email" placeholder="email@example.com" required
                  class="w-full border-2 border-ink dark:border-[#444] bg-white dark:bg-[#111] text-ink dark:text-ink-dark py-3.5 pl-10 pr-4 focus:outline-none focus:border-accent transition-colors placeholder:text-ink-muted text-sm" />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="style" class="text-xs font-black uppercase tracking-widest text-ink dark:text-ink-dark">Your Style</label>
              <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-ink-muted" style="font-size:16px">style</span>
                <select id="style" name="style"
                  class="w-full border-2 border-ink dark:border-[#444] bg-white dark:bg-[#111] text-ink dark:text-ink-dark py-3.5 pl-10 pr-8 focus:outline-none focus:border-accent transition-colors appearance-none text-sm">
                  <option value="" disabled selected>Select your vibe</option>
                  <option value="minimal">Minimalist &amp; Clean</option>
                  <option value="streetwear">Streetwear &amp; Bold</option>
                  <option value="luxury">Luxury &amp; Classic</option>
                  <option value="vibrant">Vibrant &amp; Artistic</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-ink-muted pointer-events-none" style="font-size:16px">expand_more</span>
              </div>
            </div>

            <button type="submit"
              class="w-full bg-primary border-2 border-ink text-ink font-bold text-base py-4 flex items-center justify-center gap-2 group hover:translate-x-[2px] hover:translate-y-[2px] hover:[box-shadow:none] transition-all mt-2"
              style="box-shadow:4px 4px 0 #111">
              Secure My Spot
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" style="font-size:18px">arrow_forward</span>
            </button>

          </form>

          <p class="text-center text-xs text-ink-muted dark:text-ink-muted-dark mt-5">
            By registering you agree to our
            <a href="#" class="font-bold text-ink dark:text-ink-dark hover:text-secondary dark:hover:text-primary hover:underline">Terms</a>
            and
            <a href="#" class="font-bold text-ink dark:text-ink-dark hover:text-secondary dark:hover:text-primary hover:underline">Privacy Policy</a>.
          </p>
        </div>

        <!-- Success state -->
        <div id="success-msg" class="hidden flex flex-col items-center text-center py-10 gap-4">
          <div class="w-16 h-16 bg-primary border-2 border-ink flex items-center justify-center" style="box-shadow:4px 4px 0 #111">
            <span class="material-symbols-outlined text-ink text-3xl" style="font-variation-settings:'FILL' 1">check_circle</span>
          </div>
          <h2 class="font-display text-2xl font-extrabold text-ink dark:text-ink-dark">You're on the list!</h2>
          <p class="text-ink-muted dark:text-ink-muted-dark text-sm max-w-xs leading-relaxed">We'll send your early access details to your phone and email as soon as gikomba.app launches.</p>
          <a href="index.html" class="mt-2 border-2 border-ink dark:border-[#444] text-ink dark:text-ink-dark font-bold px-6 py-3 text-sm hover:bg-primary transition-colors">
            Back to home
          </a>
        </div>

      </div>
    </div>

  </main>

  <script>
    function handleSubmit(e) {
      e.preventDefault();
      document.getElementById("form-container").classList.add("hidden");
      document.getElementById("success-msg").classList.remove("hidden");
    }
  </script>
  <script src="gikomba.js"></script>
</body>
</html>