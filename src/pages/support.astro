    <!-- ═══ APP HELP CATEGORIES ═════════════════════════════════ -->
    <section class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-16 py-12 sm:py-16" aria-labelledby="guides-heading">
      <h2 id="guides-heading" class="font-display text-2xl font-extrabold mb-7 text-ink dark:text-ink-dark">Browse Help Topics</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">

        <article class="group border-2 border-ink dark:border-[#444] bg-white dark:bg-[#1A1A1A] p-6 flex flex-col gap-4 hover:-translate-y-1 transition-transform" style="box-shadow:4px 4px 0 #111">
          <div class="w-11 h-11 border-2 border-ink dark:border-[#444] bg-accent/15 text-accent flex items-center justify-center">
            <span class="material-symbols-outlined">download</span>
          </div>
          <div>
            <h3 class="font-display text-lg font-bold text-ink dark:text-ink-dark">Getting Started</h3>
            <p class="mt-1.5 text-sm text-ink-muted dark:text-ink-muted-dark leading-relaxed">How to download, sign up, and create your first listing on gikomba.app.</p>
          </div>
          <a href="#" class="mt-auto flex items-center gap-1 text-sm font-bold text-accent hover:underline">
            12 articles <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
          </a>
        </article>

        <article class="group border-2 border-ink dark:border-[#444] bg-white dark:bg-[#1A1A1A] p-6 flex flex-col gap-4 hover:-translate-y-1 transition-transform" style="box-shadow:4px 4px 0 #111">
          <div class="w-11 h-11 border-2 border-ink dark:border-[#444] bg-secondary/15 text-secondary flex items-center justify-center">
            <span class="material-symbols-outlined">payments</span>
          </div>
          <div>
            <h3 class="font-display text-lg font-bold text-ink dark:text-ink-dark">M-Pesa &amp; Payments</h3>
            <p class="mt-1.5 text-sm text-ink-muted dark:text-ink-muted-dark leading-relaxed">How to pay, get paid, and understand how our escrow system protects you.</p>
          </div>
          <a href="#" class="mt-auto flex items-center gap-1 text-sm font-bold text-secondary hover:underline">
            8 articles <span class="material-symbols-outlined" style="font-size:14px">arrow_forward</span>
          </a>
        </article>

        <article class="group border-2 border-ink dark:border-[#444] bg-white dark:bg-[#1A1A1A] p-6 flex flex-col gap-4 hover:-translate-y-1 transition-transform" style="box-shadow:4px 4px 0 #111">
          <div class="w-11 h-11 border-2 border-ink dark:border-[#444] bg-primary/20 text-ink dark:text-ink-dark flex items-center justify-center">
            <span class="material-symbols-outlined">local_shipping</span>
          </div>
          <div>
            <h3 class="font-display text-lg font-bold text-ink dark:text-ink-dark">Delivery &amp; Meetups</h3>
            <p class="mt-1.5 text-sm text-ink-muted dark:text-ink-muted-dark leading-relaxed">Arranging meetups safely, courier options, and what to do if something goes wrong.</p>
