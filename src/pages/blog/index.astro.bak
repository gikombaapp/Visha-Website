---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate - a.data.pubDate);
---

<!DOCTYPE html>
<html lang="en" class="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Fashion Edit | gikomba.app</title>
  <meta name="description" content="Stories on Kenyan streetwear, vintage treasures, and sustainable fashion in Nairobi." />
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
  
  <!-- Tailwind -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            primary: "#B5F03A",
            secondary: "#7B4FC4",
            accent: "#007A91",
            ink: "#111111",
            "ink-muted": "#555555",
            "ink-dark": "#E8E8E8",
            "ink-muted-dark": "#9CA3AF",
          },
          fontFamily: {
            display: ["'Syne'", "sans-serif"],
            body: ["'DM Sans'", "sans-serif"],
          },
          borderRadius: {
            DEFAULT: "0px",
          },
        },
      },
    };
  </script>
  
  <style>
    body { font-family: 'DM Sans', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Syne', sans-serif; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }
  </style>
</head>
<body class="bg-white dark:bg-[#0F0F0F] text-ink dark:text-ink-dark antialiased transition-colors duration-200">

  <div id="site-nav"></div>

  <main class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-16 py-16">
    <div class="mb-12">
      <h1 class="font-display text-5xl md:text-6xl font-extrabold text-ink dark:text-ink-dark mb-4">
        The Fashion <span class="bg-primary px-2 text-ink">Edit</span>
      </h1>
      <p class="text-ink-muted dark:text-ink-muted-dark text-lg max-w-2xl">
        Exploring the pulse of Kenyan style, vintage treasures, and the rise of sustainable culture.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedPosts.map(post => (
        <article class="bg-white dark:bg-[#1A1A1A] border-2 border-ink dark:border-[#444] p-6 hover:shadow-lg transition-all" style="box-shadow: 4px 4px 0 #111">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-secondary text-sm">article</span>
            <span class="text-xs font-bold text-secondary uppercase">{post.data.tags[0]}</span>
          </div>
          <h2 class="font-display text-xl font-bold text-ink dark:text-ink-dark mb-2">{post.data.title}</h2>
          <p class="text-ink-muted dark:text-ink-muted-dark text-sm mb-4 leading-relaxed">{post.data.description}</p>
          <div class="flex items-center justify-between">
            <time class="text-xs text-ink-muted dark:text-ink-muted-dark">{post.data.pubDate.toLocaleDateString()}</time>
            <a href={`/blog/${post.id}`} class="text-secondary dark:text-primary font-bold text-sm flex items-center gap-1 hover:gap-2 transition-all">
              Read <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </main>

  <footer class="border-t-2 border-ink dark:border-[#444] bg-white dark:bg-[#0F0F0F] py-8 text-center text-sm text-ink-muted dark:text-ink-muted-dark">
    <p>© 2024 gikomba.app — Built for the pride of Africa.</p>
  </footer>

  <script is:inline src="/gikomba.js"></script>
</body>
</html>
