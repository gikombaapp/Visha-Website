---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);


// Get all other posts (excluding current)
const allPosts = await getCollection('blog');
const otherPosts = allPosts.filter(p => p.id !== post.id).sort((a, b) => b.data.pubDate - a.data.pubDate);
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{post.data.title} | The Fashion Edit</title>
  <link rel="stylesheet" href="/src/styles/global.css">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body class="bg-black text-white">
  <main class="max-w-4xl mx-auto px-4 py-12">
    <!-- Back button -->
    <div class="mb-8">
      <a href="/blog" class="back-button">← All posts</a>
    </div>

    <!-- Current post -->
    <article class="mb-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-3 text-white">{post.data.title}</h1>
      <div class="text-gray-400 mb-6">
        {new Date(post.data.pubDate).toLocaleDateString('en-US', { 
          year: 'numeric', 
          month: 'long', 
          day: 'numeric' 
        })}
      </div>
          <!-- Tags -->
    {post.data.tags && post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 my-4">
        {post.data.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
      <div class="blog-content">
        <Content />
      </div>
    </article>

    <!-- Separator -->
    <hr class="my-12 border-gray-800">

    <!-- Other posts section -->
    <section>
      <h2 class="text-2xl font-bold mb-6">More from The Fashion Edit</h2>
      <div class="other-posts-grid">
  {otherPosts.map(other => (
    <a href={`/blog/${other.id}`} class="block no-underline">
      <div class="other-post-card">
        <h3 class="other-post-title">{other.data.title}</h3>
        <p class="other-post-description">{other.data.description}</p>
      </div>
    </a>
  ))}
</div>
    </section>
  </main>
</body>
</html>
