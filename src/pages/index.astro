---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<Layout
  title="visha — for the collective | Pre-loved Fashion in Kenya"
  description="visha is the app for buying and selling pre-loved fashion in Kenya. M-Pesa ready, community verified, 100% sustainable."
  canonical="https://visha.app/"
>

  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="container-visha grid gap-12 items-center pt-12 pb-12 lg:grid-cols-2 lg:gap-20 lg:pt-20" aria-labelledby="hero-heading">

    <!-- Text -->
    <div class="flex flex-col gap-6 order-2 lg:order-1">
      <span class="tag tag-garnet">Coming to Nairobi</span>

      <h1 id="hero-heading" class="text-[clamp(2.4rem,6vw,4.5rem)] font-extrabold text-charcoal dark:text-alabaster leading-none">
        The thrift app<br />
        <span class="highlight">built for Kenya.</span>
      </h1>

      <p class="text-base text-ink-muted dark:text-ink-muted-dark leading-[1.7] max-w-[42ch]">
        <strong>visha</strong> brings the spirit of Gikomba Market to your phone. Buy and sell pre-loved fashion across Nairobi — pay with M-Pesa, chat in-app, and shop sustainably.
      </p>

      <WaitlistForm id="hero" btnLabel="Join Waitlist" />
    </div>

    <!-- Phone mockup -->
    <div class="relative flex justify-center order-1 lg:order-2 lg:justify-end" aria-hidden="true">
      <div class="absolute bottom-[-1rem] right-[-1rem] w-full h-full max-w-[240px] bg-alabaster-dark border-2 border-charcoal dark:bg-warm-dusk"></div>
      <div class="phone-mockup relative z-10 w-[240px] sm:w-[270px]" style="aspect-ratio:9/19">
        <div class="absolute inset-0 pt-5 bg-parchment flex flex-col overflow-hidden">
          <!-- App header -->
          <div class="px-3 pt-1.5 pb-2 bg-white border-b border-charcoal flex items-center justify-between shrink-0" style="border-bottom-width:1.5px">
            <span class="font-display font-extrabold text-[10px] text-charcoal">visha</span>
            <span class="material-symbols-outlined text-charcoal" style="font-size:13px">notifications</span>
          </div>
          <!-- Search -->
          <div class="mx-2 my-1.5 border border-charcoal bg-white px-2 py-1 flex gap-1 items-center text-[8px] text-ink-muted shrink-0">
            <span class="material-symbols-outlined" style="font-size:11px">search</span>
            <span>vintage, streetwear...</span>
          </div>
          <!-- Pills -->
          <div class="flex gap-1 px-2 mb-1.5 shrink-0">
            <span class="bg-garnet text-white border border-mahogany px-1.5 py-0.5 text-[7px] font-bold whitespace-nowrap">All</span>
            <span class="bg-white border border-charcoal text-charcoal px-1.5 py-0.5 text-[7px] font-bold whitespace-nowrap">Streetwear</span>
            <span class="bg-white border border-charcoal text-charcoal px-1.5 py-0.5 text-[7px] font-bold whitespace-nowrap">Vintage</span>
            <span class="bg-white border border-charcoal text-charcoal px-1.5 py-0.5 text-[7px] font-bold whitespace-nowrap">Shoes</span>
          </div>
          <!-- Grid -->
          <div class="grid grid-cols-2 gap-1.5 px-2 flex-1 overflow-hidden">
            <div class="border border-charcoal bg-white overflow-hidden">
              <div class="aspect-square bg-cover bg-center" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBorhG7xFUUxIYRDQe8VgF2sjybia3Yci63Z60k9uT7YY_9EfGJmlIHE1fkvuo-zEopHBy5EsB7o7bFWc-fF7LJTb7LhA3khbtQc47XYUBZLCO3DQWUPfRK45S71xd8gdGZgmPUD2mlZIiFQ4stq9oWSX6WfDJXrx5BKOOpIeFpFka7CHhk0FqhmjXCm7dtDzTlOBW9ND1-DDFy2gOcu5PVPGbJ9p6Hky86faP4TlAQA8gtZHeF0xG8eJEvGLwfQO4dHnXGRyEY9wE")'></div>
              <div class="px-1 py-0.5 text-[7px] font-bold text-charcoal">Vintage Denim<div class="text-garnet">Ksh 1,200</div></div>
            </div>
            <div class="border border-charcoal bg-white overflow-hidden">
              <div class="aspect-square bg-cover bg-center" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCkefBJFnKHBDTw8og8vBgEWbjGxSPcSizq6rewIxLYhUx8iiK1d0eYACtCjvq1Lq5BwgxPF_2IVdXo0jl9g-EI95NWcTWv7UWI_AjTB4G-sXn8l3m1gM39kbnwWHCCmfFIi1_C_B9w_y7EygMKVgsjmiOBR_xfG1uTGfBEheqhO3mLEMJiZBSF5FB8iXmzRjBP7xlVEs0l4c8SE0KQeSksIt964tvfohw4un-keXTM87VdqC92MA1uUfPSLGwDE7Fp7kx68597iL8")'></div>
              <div class="px-1 py-0.5 text-[7px] font-bold text-charcoal">Jordan 1<div class="text-garnet">Ksh 4,500</div></div>
            </div>
            <div class="border border-charcoal bg-white overflow-hidden">
              <div class="aspect-square bg-cover bg-center" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuAcTQajgNqruqsFy1uUXQfDKZn6Q8fi6e7vsODiGr7tc1PW1vakeTO01kDK8w3CLl1VJfPqISmrY7tqK9nr4uyFBs1vLSrAK2qHkuvjV9KHtXSd2AwfeLxnYW2fBO5CxtCzyWBgMGMvbpqLK91Ue5pSeFODmcLUgsY-sa8B0gDVHexEf9278XubxKFxnE8ZiNw4382Obzrs-G2fjloWol3q0qoyTRghad2U0wzuvwL3iQd16ONYUE2Z-Y4RrJ1xj3kVk4Bk14WlJwk")'></div>
              <div class="px-1 py-0.5 text-[7px] font-bold text-charcoal">Hoodie<div class="text-garnet">Ksh 800</div></div>
            </div>
            <div class="border border-charcoal bg-white overflow-hidden">
              <div class="aspect-square bg-cover bg-center" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDwZVj5_fiXIXBTOfTZWkxyQDhjdtApEJEdugKrkUnyFsWb_V79TaVteHizBo4PBYfZp4VGdP6NkTiJNk6PPhaYxLTSBq2P1uTBeVrNmT8ckLCmFxN0A0m-DljIwKrlfFibCO6-AdD3S7-Vgz_cAwvZ0vQMLbSlRuFDbyuZ1W3QZzJ4vs047BcI9FRTTT9YIKneA4WpWeG6i8f068PPLgaHe7oD-xvx2E7LFk8T69D5l0NvZMtpTw_gXpNArsDo_aeecBLUqBV9tRY")'></div>
              <div class="px-1 py-0.5 text-[7px] font-bold text-charcoal">Gold Chain<div class="text-garnet">Ksh 350</div></div>
            </div>
          </div>
          <!-- Tab bar -->
          <div class="bg-white border-t border-charcoal flex justify-around py-1.5 shrink-0">
            <span class="material-symbols-outlined text-garnet" style="font-size:16px;font-variation-settings:'FILL' 1">home</span>
            <span class="material-symbols-outlined text-ink-muted" style="font-size:16px">search</span>
            <span class="material-symbols-outlined text-ink-muted" style="font-size:16px">add_circle</span>
            <span class="material-symbols-outlined text-ink-muted" style="font-size:16px">favorite</span>
            <span class="material-symbols-outlined text-ink-muted" style="font-size:16px">person</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TICKER ═══════════════════════════════════════════ -->
  <div class="border-y-2 border-charcoal bg-garnet overflow-hidden py-3 select-none" aria-hidden="true">
    <div class="marquee-track font-display font-bold text-[0.8rem] uppercase tracking-widest text-white whitespace-nowrap">
      <span class="px-6">Vintage · Streetwear · M-Pesa Ready · Nairobi · Gikomba Finds · Sustainable Fashion · Local Sellers · Pre-loved · Authentic Drops · Community Verified · </span>
      <span class="px-6">Vintage · Streetwear · M-Pesa Ready · Nairobi · Gikomba Finds · Sustainable Fashion · Local Sellers · Pre-loved · Authentic Drops · Community Verified · </span>
    </div>
  </div>

  <!-- ═══ FEATURES ═════════════════════════════════════════ -->
  <section class="section-visha container-visha" aria-labelledby="features-heading">
    <header class="mb-10">
      <h2 id="features-heading" class="section-title">Everything you need,<br class="hidden sm:block" /> in one app.</h2>
      <p class="section-body">visha is designed from the ground up for how Kenyans actually buy and sell.</p>
    </header>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--garnet"><span class="material-symbols-outlined" style="font-size:20px">payments</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">M-Pesa Checkout</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Pay and get paid instantly. No bank account required — just your phone number.</p>
      </article>

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--charcoal"><span class="material-symbols-outlined" style="font-size:20px">add_a_photo</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">List in 60 Seconds</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Snap a photo, set a price, go live. Your listing reaches buyers in Nairobi instantly.</p>
      </article>

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--garnet"><span class="material-symbols-outlined" style="font-size:20px">forum</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">In-App Chat</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Negotiate and arrange meetups — all inside the app, without sharing your number.</p>
      </article>

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--charcoal"><span class="material-symbols-outlined" style="font-size:20px">verified_user</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">Verified Sellers</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Every seller is ID-verified. Ratings and reviews mean you can shop with confidence.</p>
      </article>

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--garnet"><span class="material-symbols-outlined" style="font-size:20px">local_shipping</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">Safe Delivery</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Meet up locally or use our courier partners across Nairobi, Mombasa, and Kisumu.</p>
      </article>

      <!-- Accent card -->
      <article class="p-6 flex flex-col gap-3.5 bg-charcoal border-2 border-charcoal shadow-[5px_5px_0_#6B0005]">
        <div class="icon-box icon-box--alabaster"><span class="material-symbols-outlined" style="font-size:20px">eco</span></div>
        <h3 class="font-display text-lg font-bold text-parchment">100% Sustainable</h3>
        <p class="text-sm text-alabaster/70 leading-[1.65]">Every purchase is a vote against fast fashion. We track your carbon savings too.</p>
      </article>

    </div>
  </section>

  <!-- ═══ 3 STEPS ══════════════════════════════════════════ -->
  <section class="bg-charcoal border-y-2 border-charcoal py-16 lg:py-24" aria-labelledby="steps-heading">
    <div class="container-visha">
      <h2 id="steps-heading" class="section-title text-center text-alabaster mb-12">Up and running in minutes.</h2>
      <div class="grid gap-8 sm:grid-cols-3">

        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-14 h-14 border-2 border-mahogany bg-garnet text-white flex items-center justify-center shadow-[4px_4px_0_#4A0003]">
            <span class="material-symbols-outlined" style="font-size:1.5rem">download</span>
          </div>
          <div class="font-display text-[4rem] font-extrabold text-alabaster/[0.08] leading-none select-none">01</div>
          <h3 class="font-display text-[1.2rem] font-bold text-alabaster">Download the app</h3>
          <p class="text-sm text-alabaster/60 leading-[1.65]">Free on iOS and Android. Sign up with your phone number — no email needed.</p>
        </div>

        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-14 h-14 border-2 border-alabaster bg-alabaster text-charcoal flex items-center justify-center shadow-[4px_4px_0_#CFC9C5]">
            <span class="material-symbols-outlined" style="font-size:1.5rem">explore</span>
          </div>
          <div class="font-display text-[4rem] font-extrabold text-alabaster/[0.08] leading-none select-none">02</div>
          <h3 class="font-display text-[1.2rem] font-bold text-alabaster">Browse or list</h3>
          <p class="text-sm text-alabaster/60 leading-[1.65]">Find hidden gems or snap your closet and go live in under a minute.</p>
        </div>

        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-14 h-14 border-2 border-warm-dusk bg-warm-dusk text-alabaster flex items-center justify-center shadow-[4px_4px_0_#28231E]">
            <span class="material-symbols-outlined" style="font-size:1.5rem">payments</span>
          </div>
          <div class="font-display text-[4rem] font-extrabold text-alabaster/[0.08] leading-none select-none">03</div>
          <h3 class="font-display text-[1.2rem] font-bold text-alabaster">Pay with M-Pesa</h3>
          <p class="text-sm text-alabaster/60 leading-[1.65]">Funds held in escrow until you confirm arrival. Then released instantly.</p>
        </div>

      </div>
      <div class="text-center mt-12">
        <a href="/how" class="btn-alabaster">
          See full walkthrough
          <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ════════════════════════════════════ -->
  <section class="section-visha container-visha" aria-labelledby="testimonials-heading">
    <h2 id="testimonials-heading" class="section-title mb-8">What the community says.</h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">

      <blockquote class="card-brutalist p-6">
        <p class="text-[0.9375rem] italic text-ink-muted dark:text-ink-muted-dark leading-[1.65] mb-5">"I sold my old Jordans in under an hour. The M-Pesa integration is seamless — I didn't even have to leave my house."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 border-2 border-charcoal bg-garnet flex items-center justify-center font-display font-bold text-[0.8125rem] text-white shrink-0">BK</div>
          <div>
            <cite class="font-bold text-sm text-charcoal dark:text-alabaster not-italic block">Brian K.</cite>
            <p class="text-xs text-ink-muted dark:text-ink-muted-dark">Seller · Westlands</p>
          </div>
        </footer>
      </blockquote>

      <blockquote class="p-6 bg-garnet border-2 border-mahogany shadow-[5px_5px_0_#28231E]">
        <p class="text-[0.9375rem] italic text-alabaster/80 leading-[1.65] mb-5">"Found a vintage Levi's jacket that wasn't anywhere else in Nairobi. Gikomba market vibes, from my phone."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 border-2 border-charcoal bg-charcoal flex items-center justify-center font-display font-bold text-[0.8125rem] text-alabaster shrink-0">AM</div>
          <div>
            <cite class="font-bold text-sm text-alabaster not-italic block">Amina M.</cite>
            <p class="text-xs text-alabaster/60">Buyer · Kileleshwa</p>
          </div>
        </footer>
      </blockquote>

      <blockquote class="card-brutalist p-6">
        <p class="text-[0.9375rem] italic text-ink-muted dark:text-ink-muted-dark leading-[1.65] mb-5">"As a small thrift business in Gikomba, this app gave us access to customers we never had before."</p>
        <footer class="flex items-center gap-3">
          <div class="w-10 h-10 border-2 border-charcoal bg-warm-dusk flex items-center justify-center font-display font-bold text-[0.8125rem] text-alabaster shrink-0">JO</div>
          <div>
            <cite class="font-bold text-sm text-charcoal dark:text-alabaster not-italic block">James O.</cite>
            <p class="text-xs text-ink-muted dark:text-ink-muted-dark">Seller · Gikomba Market</p>
          </div>
        </footer>
      </blockquote>

    </div>
  </section>

  <!-- ═══ BOTTOM CTA ════════════════════════════════════════ -->
  <section class="bg-garnet border-t-2 border-charcoal py-16 lg:py-20" aria-labelledby="cta-heading">
    <div class="container-visha flex flex-col items-center gap-5 text-center">
      <h2 id="cta-heading" class="text-[clamp(1.75rem,4vw,3rem)] font-extrabold text-white">Ready to thrift smarter?</h2>
      <p class="text-base text-alabaster/80 max-w-[42ch]">Join the visha waitlist and be first to buy and sell pre-loved fashion in Nairobi.</p>
      <div class="max-w-[28rem] w-full [&_.waitlist-success]:text-alabaster">
        <WaitlistForm id="bottom" dark={true} btnLabel="Join Waitlist" />
      </div>
    </div>
  </section>

</Layout>
