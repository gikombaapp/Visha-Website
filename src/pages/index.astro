  <!-- ═══ BOTTOM CTA ════════════════════════════════════════ -->
  <section class="bg-garnet border-t-2 border-charcoal py-16 lg:py-20" aria-labelledby="cta-heading">
    <div class="container-visha flex flex-col items-center gap-5 text-center">
      <h2 id="cta-heading" class="text-[clamp(1.75rem,4vw,3rem)] font-extrabold text-white">Ready to thrift smarter?</h2>
      <p class="text-base text-alabaster/80 max-w-[42ch]">Join the visha waitlist and be first to buy and sell pre-loved fashion in Nairobi.</p>
      <div class="max-w-[28rem] w-full [&_.waitlist-success]:text-alabaster">
        <WaitlistForm id="bottom" dark={true} btnLabel="Join Waitlist" />
