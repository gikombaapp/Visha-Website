---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import PhoneMockup from '../components/PhoneMockup.astro';
---

<Layout
  title="visha — for the collective | Pre-loved Fashion in Kenya"
  description="visha is the app for buying and selling pre-loved fashion in Kenya. M-Pesa ready, community verified, 100% sustainable."
  canonical="https://visha.app/"
>

  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="container-visha grid gap-12 items-center pt-12 pb-12 lg:grid-cols-2 lg:gap-20 lg:pt-20" aria-labelledby="hero-heading">

    <!-- Text -->
    <div class="flex flex-col gap-6 order-2 lg:order-1">
      <span class="tag tag-garnet">Coming to Nairobi</span>

      <h1 id="hero-heading" class="text-[clamp(2.4rem,6vw,4.5rem)] font-extrabold text-charcoal dark:text-alabaster leading-none">
        The thrift app<br />
        <span class="highlight">built for Kenya.</span>
      </h1>

      <p class="text-base text-ink-muted dark:text-ink-muted-dark leading-[1.7] max-w-[42ch]">
        <strong>visha</strong> brings the spirit of Gikomba Market to your phone. Buy and sell pre-loved fashion across Nairobi; pay with M-Pesa, chat in-app, and shop sustainably.
      </p>

      <WaitlistForm id="hero" btnLabel="Join Waitlist" />
    </div>

    <!-- Phone mockup -->
    <PhoneMockup />
  </section>

  <!-- ═══ TICKER ═══════════════════════════════════════════ -->
  <div class="border-y-2 border-charcoal bg-lime overflow-hidden py-3 select-none" aria-hidden="true">
    <div class="marquee-track font-display font-bold text-[0.8rem] uppercase tracking-widest text-charcoal whitespace-nowrap">
      <span class="px-6">Vintage · Streetwear · M-Pesa Ready · Nairobi · Gikomba Finds · Sustainable Fashion · Local Sellers · Pre-loved · Authentic Drops · Community Verified · </span>
      <span class="px-6">Vintage · Streetwear · M-Pesa Ready · Nairobi · Gikomba Finds · Sustainable Fashion · Local Sellers · Pre-loved · Authentic Drops · Community Verified · </span>
    </div>
  </div>

  <!-- ═══ FEATURES ═════════════════════════════════════════ -->
  <section class="section-visha container-visha" aria-labelledby="features-heading">
    <header class="mb-10">
      <h2 id="features-heading" class="section-title">Everything you need,<br class="hidden sm:block" /> in one app.</h2>
      <p class="section-body">visha is designed from the ground up for how Kenyans actually buy and sell.</p>
    </header>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--garnet"><span class="material-symbols-outlined" style="font-size:20px">payments</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">M-Pesa Checkout</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Pay and get paid with your M-Pesa. No bank account required, just your phone number.</p>
      </article>

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--charcoal"><span class="material-symbols-outlined" style="font-size:20px">add_a_photo</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">List in 60 Seconds</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Snap a photo, set a price, go live. Your listing reaches buyers in Nairobi instantly.</p>
      </article>

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--garnet"><span class="material-symbols-outlined" style="font-size:20px">forum</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">In-App Chat</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Negotiate and arrange meetups and deliveries; all inside the app, without sharing your number.</p>
      </article>

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--charcoal"><span class="material-symbols-outlined" style="font-size:20px">verified_user</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">Verified Sellers</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Find ID-Verified sellers. Ratings and reviews mean you can shop with confidence.</p>
      </article>

      <article class="card-brutalist p-6 flex flex-col gap-3.5">
        <div class="icon-box icon-box--garnet"><span class="material-symbols-outlined" style="font-size:20px">local_shipping</span></div>
        <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">Delivery or Pickup</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Meet up locally for pickup, or get your items delivered to you.</p>
      </article>

      <!-- Accent card -->
      <article class="p-6 flex flex-col gap-3.5 bg-charcoal border-2 border-charcoal shadow-[5px_5px_0_#C6FF33]">
        <div class="icon-box icon-box--alabaster"><span class="material-symbols-outlined" style="font-size:20px">eco</span></div>
        <h3 class="font-display text-lg font-bold text-parchment">100% Sustainable</h3>
        <p class="text-sm text-alabaster/70 leading-[1.65]">Every purchase is a vote against fast fashion. We track your carbon savings too.</p>
      </article>

    </div>
  </section>

  <!-- ═══ 3 STEPS ══════════════════════════════════════════ -->
  <section class="bg-charcoal border-y-2 border-charcoal py-16 lg:py-24" aria-labelledby="steps-heading">
    <div class="container-visha">
      <h2 id="steps-heading" class="section-title text-center text-alabaster mb-12">Up and running in minutes.</h2>
      <div class="grid gap-8 sm:grid-cols-3">

        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-14 h-14 border-2 border-mahogany bg-garnet text-white flex items-center justify-center shadow-[4px_4px_0_#C6FF33]">
            <span class="material-symbols-outlined" style="font-size:1.5rem">download</span>
          </div>
          <div class="font-display text-[4rem] font-extrabold text-alabaster/[0.08] leading-none select-none">01</div>
          <h3 class="font-display text-[1.2rem] font-bold text-alabaster">Download the app</h3>
          <p class="text-sm text-alabaster/60 leading-[1.65]">Free on the Web. Sign up with your phone number or email. Choose whichever fits what you have. iOS and Android Apps coming soon</p>
        </div>

        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-14 h-14 border-2 border-alabaster bg-alabaster text-charcoal flex items-center justify-center shadow-[4px_4px_0_#D9D9D9]">
            <span class="material-symbols-outlined" style="font-size:1.5rem">explore</span>
          </div>
          <div class="font-display text-[4rem] font-extrabold text-alabaster/[0.08] leading-none select-none">02</div>
          <h3 class="font-display text-[1.2rem] font-bold text-alabaster">Browse or list</h3>
          <p class="text-sm text-alabaster/60 leading-[1.65]">Find hidden gems or snap your closet and go live in under a minute.</p>
        </div>

        <div class="flex flex-col items-center text-center gap-3">
          <div class="w-14 h-14 border-2 border-warm-dusk bg-warm-dusk text-alabaster flex items-center justify-center shadow-[4px_4px_0_#000000]">
            <span class="material-symbols-outlined" style="font-size:1.5rem">payments</span>
          </div>
          <div class="font-display text-[4rem] font-extrabold text-alabaster/[0.08] leading-none select-none">03</div>
          <h3 class="font-display text-[1.2rem] font-bold text-alabaster">Pay with M-Pesa</h3>
          <p class="text-sm text-alabaster/60 leading-[1.65]">Funds held in escrow until you confirm arrival. Then released instantly.</p>
        </div>

      </div>
      <div class="text-center mt-12">
        <a href="/how" class="btn-alabaster">
          See full walkthrough
          <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

