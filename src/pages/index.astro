---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<Layout
  title="visha — for the collective | Pre-loved Fashion in Kenya"
  description="visha is the app for buying and selling pre-loved fashion in Kenya. M-Pesa ready, community verified, 100% sustainable."
  canonical="https://visha.app/"
>

  <!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="hero section container" aria-labelledby="hero-heading">
    <div class="hero-text">

      <span class="tag tag-garnet">Coming to Nairobi</span>

      <h1 id="hero-heading" class="hero-h1">
        The thrift app<br />
        <span class="hero-highlight">built for Kenya.</span>
      </h1>

      <p class="hero-body">
        <strong>visha</strong> brings the spirit of Gikomba Market to your phone. Buy and sell pre-loved fashion across Nairobi — pay with M-Pesa, chat in-app, and shop sustainably.
      </p>

      <WaitlistForm id="hero" btnLabel="Join Waitlist" />

    </div>

    <!-- Phone mockup -->
    <div class="hero-mockup-wrap" aria-hidden="true">
      <div class="hero-mockup-offset"></div>
      <div class="phone-frame hero-phone">
        <div class="phone-screen">
          <!-- App header -->
          <div class="app-header">
            <span class="app-logo-text">visha</span>
            <span class="material-symbols-outlined app-icon">notifications</span>
          </div>
          <!-- Search -->
          <div class="app-search">
            <span class="material-symbols-outlined" style="font-size:11px">search</span>
            <span>vintage, streetwear...</span>
          </div>
          <!-- Pills -->
          <div class="app-pills">
            <span class="pill pill--active">All</span>
            <span class="pill">Streetwear</span>
            <span class="pill">Vintage</span>
            <span class="pill">Shoes</span>
          </div>
          <!-- Grid -->
          <div class="app-grid">
            <div class="app-card">
              <div class="app-card-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBorhG7xFUUxIYRDQe8VgF2sjybia3Yci63Z60k9uT7YY_9EfGJmlIHE1fkvuo-zEopHBy5EsB7o7bFWc-fF7LJTb7LhA3khbtQc47XYUBZLCO3DQWUPfRK45S71xd8gdGZgmPUD2mlZIiFQ4stq9oWSX6WfDJXrx5BKOOpIeFpFka7CHhk0FqhmjXCm7dtDzTlOBW9ND1-DDFy2gOcu5PVPGbJ9p6Hky86faP4TlAQA8gtZHeF0xG8eJEvGLwfQO4dHnXGRyEY9wE")'></div>
              <div class="app-card-info"><div>Vintage Denim</div><div class="app-price">Ksh 1,200</div></div>
            </div>
            <div class="app-card">
              <div class="app-card-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCkefBJFnKHBDTw8og8vBgEWbjGxSPcSizq6rewIxLYhUx8iiK1d0eYACtCjvq1Lq5BwgxPF_2IVdXo0jl9g-EI95NWcTWv7UWI_AjTB4G-sXn8l3m1gM39kbnwWHCCmfFIi1_C_B9w_y7EygMKVgsjmiOBR_xfG1uTGfBEheqhO3mLEMJiZBSF5FB8iXmzRjBP7xlVEs0l4c8SE0KQeSksIt964tvfohw4un-keXTM87VdqC92MA1uUfPSLGwDE7Fp7kx68597iL8")'></div>
              <div class="app-card-info"><div>Jordan 1</div><div class="app-price">Ksh 4,500</div></div>
            </div>
            <div class="app-card">
              <div class="app-card-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuAcTQajgNqruqsFy1uUXQfDKZn6Q8fi6e7vsODiGr7tc1PW1vakeTO01kDK8w3CLl1VJfPqISmrY7tqK9nr4uyFBs1vLSrAK2qHkuvjV9KHtXSd2AwfeLxnYW2fBO5CxtCzyWBgMGMvbpqLK91Ue5pSeFODmcLUgsY-sa8B0gDVHexEf9278XubxKFxnE8ZiNw4382Obzrs-G2fjloWol3q0qoyTRghad2U0wzuvwL3iQd16ONYUE2Z-Y4RrJ1xj3kVk4Bk14WlJwk")'></div>
              <div class="app-card-info"><div>Hoodie</div><div class="app-price">Ksh 800</div></div>
            </div>
            <div class="app-card">
              <div class="app-card-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDwZVj5_fiXIXBTOfTZWkxyQDhjdtApEJEdugKrkUnyFsWb_V79TaVteHizBo4PBYfZp4VGdP6NkTiJNk6PPhaYxLTSBq2P1uTBeVrNmT8ckLCmFxN0A0m-DljIwKrlfFibCO6-AdD3S7-Vgz_cAwvZ0vQMLbSlRuFDbyuZ1W3QZzJ4vs047BcI9FRTTT9YIKneA4WpWeG6i8f068PPLgaHe7oD-xvx2E7LFk8T69D5l0NvZMtpTw_gXpNArsDo_aeecBLUqBV9tRY")'></div>
              <div class="app-card-info"><div>Gold Chain</div><div class="app-price">Ksh 350</div></div>
            </div>
          </div>
          <!-- Bottom tab bar -->
          <div class="app-tabbar">
            <span class="material-symbols-outlined app-tab app-tab--active" style="font-variation-settings:'FILL' 1">home</span>
            <span class="material-symbols-outlined app-tab">search</span>
            <span class="material-symbols-outlined app-tab">add_circle</span>
            <span class="material-symbols-outlined app-tab">favorite</span>
            <span class="material-symbols-outlined app-tab">person</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TICKER ═══════════════════════════════════════════ -->
  <div class="ticker" aria-hidden="true">
    <div class="marquee-track ticker-track">
      <span>Vintage · Streetwear · M-Pesa Ready · Nairobi · Gikomba Finds · Sustainable Fashion · Local Sellers · Pre-loved · Authentic Drops · Community Verified · </span>
      <span>Vintage · Streetwear · M-Pesa Ready · Nairobi · Gikomba Finds · Sustainable Fashion · Local Sellers · Pre-loved · Authentic Drops · Community Verified · </span>
    </div>
  </div>

  <!-- ═══ FEATURES ═════════════════════════════════════════ -->
  <section class="section container" aria-labelledby="features-heading">
    <header class="features-header">
      <h2 id="features-heading" class="section-title">Everything you need,<br class="hide-sm" /> in one app.</h2>
      <p class="section-body">visha is designed from the ground up for how Kenyans actually buy and sell.</p>
    </header>

    <div class="features-grid">

      <article class="feature-card card">
        <div class="feature-icon feature-icon--garnet">
          <span class="material-symbols-outlined">payments</span>
        </div>
        <h3 class="feature-title">M-Pesa Checkout</h3>
        <p class="feature-body">Pay and get paid instantly. No bank account required — just your phone number.</p>
      </article>

      <article class="feature-card card">
        <div class="feature-icon feature-icon--charcoal">
          <span class="material-symbols-outlined">add_a_photo</span>
        </div>
        <h3 class="feature-title">List in 60 Seconds</h3>
        <p class="feature-body">Snap a photo, set a price, go live. Your listing reaches buyers in Nairobi instantly.</p>
      </article>

      <article class="feature-card card">
        <div class="feature-icon feature-icon--garnet">
          <span class="material-symbols-outlined">forum</span>
        </div>
        <h3 class="feature-title">In-App Chat</h3>
        <p class="feature-body">Negotiate and arrange meetups — all inside the app, without sharing your number.</p>
      </article>

      <article class="feature-card card">
        <div class="feature-icon feature-icon--charcoal">
          <span class="material-symbols-outlined">verified_user</span>
        </div>
        <h3 class="feature-title">Verified Sellers</h3>
        <p class="feature-body">Every seller is ID-verified. Ratings and reviews mean you can shop with confidence.</p>
      </article>

      <article class="feature-card card">
        <div class="feature-icon feature-icon--garnet">
          <span class="material-symbols-outlined">local_shipping</span>
        </div>
        <h3 class="feature-title">Safe Delivery</h3>
        <p class="feature-body">Meet up locally or use our courier partners across Nairobi, Mombasa, and Kisumu.</p>
      </article>

      <article class="feature-card feature-card--accent">
        <div class="feature-icon feature-icon--white">
          <span class="material-symbols-outlined">eco</span>
        </div>
        <h3 class="feature-title" style="color:var(--off-white)">100% Sustainable</h3>
        <p class="feature-body" style="color:rgba(230,225,222,0.7)">Every purchase is a vote against fast fashion. We track your carbon savings too.</p>
      </article>

    </div>
  </section>

  <!-- ═══ 3 STEPS ══════════════════════════════════════════ -->
  <section class="steps-section" aria-labelledby="steps-heading">
    <div class="container">
      <h2 id="steps-heading" class="section-title steps-title">Up and running in minutes.</h2>
      <div class="steps-grid">

        <div class="step">
          <div class="step-icon step-icon--1">
            <span class="material-symbols-outlined">download</span>
          </div>
          <div class="step-num" aria-hidden="true">01</div>
          <h3 class="step-title">Download the app</h3>
          <p class="step-body">Free on iOS and Android. Sign up with your phone number — no email needed.</p>
        </div>

        <div class="step">
          <div class="step-icon step-icon--2">
            <span class="material-symbols-outlined">explore</span>
          </div>
          <div class="step-num" aria-hidden="true">02</div>
          <h3 class="step-title">Browse or list</h3>
          <p class="step-body">Find hidden gems or snap your closet and go live in under a minute.</p>
        </div>

        <div class="step">
          <div class="step-icon step-icon--3">
            <span class="material-symbols-outlined">payments</span>
          </div>
          <div class="step-num" aria-hidden="true">03</div>
          <h3 class="step-title">Pay with M-Pesa</h3>
          <p class="step-body">Funds held in escrow until you confirm arrival. Then released instantly.</p>
        </div>

      </div>
      <div style="text-align:center; margin-top:3rem">
        <a href="/how" class="btn btn-alabaster">
          See full walkthrough
          <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ════════════════════════════════════ -->
  <section class="section container" aria-labelledby="testimonials-heading">
    <h2 id="testimonials-heading" class="section-title" style="margin-bottom:2rem">What the community says.</h2>
    <div class="testimonials-grid">

      <blockquote class="card testimonial">
        <p class="testimonial-quote">"I sold my old Jordans in under an hour. The M-Pesa integration is seamless — I didn't even have to leave my house."</p>
        <footer class="testimonial-footer">
          <div class="avatar" style="background:var(--garnet)">BK</div>
          <div>
            <cite class="testimonial-name">Brian K.</cite>
            <p class="testimonial-role">Seller · Westlands</p>
          </div>
        </footer>
      </blockquote>

      <blockquote class="testimonial testimonial--garnet">
        <p class="testimonial-quote" style="color:rgba(230,225,222,0.8)">"Found a vintage Levi's jacket that wasn't anywhere else in Nairobi. Gikomba market vibes, from my phone."</p>
        <footer class="testimonial-footer">
          <div class="avatar" style="background:var(--charcoal); color:var(--alabaster)">AM</div>
          <div>
            <cite class="testimonial-name" style="color:var(--alabaster)">Amina M.</cite>
            <p class="testimonial-role" style="color:rgba(230,225,222,0.6)">Buyer · Kileleshwa</p>
          </div>
        </footer>
      </blockquote>

      <blockquote class="card testimonial">
        <p class="testimonial-quote">"As a small thrift business in Gikomba, this app gave us access to customers we never had before."</p>
        <footer class="testimonial-footer">
          <div class="avatar" style="background:var(--charcoal-soft)">JO</div>
          <div>
            <cite class="testimonial-name">James O.</cite>
            <p class="testimonial-role">Seller · Gikomba Market</p>
          </div>
        </footer>
      </blockquote>

    </div>
  </section>

  <!-- ═══ BOTTOM CTA ════════════════════════════════════════ -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="container cta-inner">
      <h2 id="cta-heading" class="cta-title">Ready to thrift smarter?</h2>
      <p class="cta-body">Join the visha waitlist and be first to buy and sell pre-loved fashion in Nairobi.</p>
      <WaitlistForm id="bottom" dark={true} btnLabel="Join Waitlist" />
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ── */
  .hero {
    display: grid;
    gap: 3rem;
    align-items: center;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }
  @media (min-width: 1024px) {
    .hero { grid-template-columns: 1fr 1fr; gap: 5rem; padding-top: 5rem; }
  }

  .hero-text { display: flex; flex-direction: column; gap: 1.5rem; order: 2; }
  @media (min-width: 1024px) { .hero-text { order: 1; } }

  .hero-h1 {
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    font-weight: 800;
    color: var(--charcoal);
    line-height: 1.0;
  }
  body.dark .hero-h1 { color: var(--alabaster); }

  .hero-highlight {
    display: inline;
    background: var(--garnet);
    color: var(--white);
    padding: 0 0.3em;
  }

  .hero-body {
    font-size: 1rem;
    color: var(--color-ink-muted);
    line-height: 1.7;
    max-width: 42ch;
  }
  body.dark .hero-body { color: var(--color-ink-muted-dark); }

  /* Mockup */
  .hero-mockup-wrap { position: relative; display: flex; justify-content: center; order: 1; }
  @media (min-width: 1024px) { .hero-mockup-wrap { order: 2; justify-content: flex-end; } }

  .hero-mockup-offset {
    position: absolute;
    bottom: -1rem; right: -1rem;
    width: 100%; height: 100%;
    background: var(--alabaster-dark);
    border: 2px solid var(--charcoal);
    max-width: 240px;
  }
  body.dark .hero-mockup-offset { background: var(--charcoal-soft); }

  .hero-phone { position: relative; z-index: 1; width: 240px; aspect-ratio: 9/19; }
  @media (min-width: 480px) { .hero-phone { width: 270px; } }

  /* App screen internals */
  .phone-screen {
    position: absolute; inset: 0;
    padding-top: 1.25rem;
    background: var(--off-white);
    display: flex; flex-direction: column;
    overflow: hidden;
  }
  .app-header {
    padding: 0.375rem 0.75rem 0.5rem;
    background: var(--white);
    border-bottom: 1.5px solid var(--charcoal);
    display: flex; align-items: center; justify-content: space-between;
    flex-shrink: 0;
  }
  .app-logo-text { font-family: var(--font-display); font-weight: 800; font-size: 10px; color: var(--charcoal); }
  .app-icon { font-size: 13px; color: var(--charcoal); }
  .app-search {
    margin: 0.375rem 0.5rem;
    border: 1px solid var(--charcoal);
    background: var(--white);
    padding: 0.25rem 0.5rem;
    display: flex; gap: 0.25rem; align-items: center;
    font-size: 8px; color: var(--color-ink-muted);
    flex-shrink: 0;
  }
  .app-pills { display: flex; gap: 0.25rem; padding: 0 0.5rem; flex-shrink: 0; margin-bottom: 0.375rem; }
  .pill {
    background: var(--white); border: 1px solid var(--charcoal);
    padding: 0.1rem 0.4rem; font-size: 7px; font-weight: 700; color: var(--charcoal);
    white-space: nowrap;
  }
  .pill--active { background: var(--garnet); color: var(--white); border-color: var(--garnet-dark); }

  .app-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.375rem; padding: 0 0.5rem; flex: 1; overflow: hidden; }
  .app-card { border: 1px solid var(--charcoal); background: var(--white); overflow: hidden; }
  .app-card-img { aspect-ratio: 1; background-size: cover; background-position: center; }
  .app-card-info { padding: 0.2rem 0.3rem; font-size: 7px; font-weight: 700; color: var(--charcoal); }
  .app-price { color: var(--garnet); font-size: 7px; }

  .app-tabbar {
    background: var(--white); border-top: 1px solid var(--charcoal);
    display: flex; justify-content: space-around; padding: 0.35rem;
    flex-shrink: 0;
  }
  .app-tab { font-size: 16px; color: var(--color-ink-muted); }
  .app-tab--active { color: var(--garnet); }

  /* ── Ticker ── */
  .ticker {
    border-top: 2px solid var(--charcoal);
    border-bottom: 2px solid var(--charcoal);
    background: var(--garnet);
    overflow: hidden;
    padding-block: 0.75rem;
    user-select: none;
  }
  .ticker-track {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--white);
    white-space: nowrap;
  }
  .ticker-track span { padding-inline: 1.5rem; }

  /* ── Features ── */
  .features-header { margin-bottom: 2.5rem; }
  .features-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px)  { .features-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .features-grid { grid-template-columns: repeat(3, 1fr); } }

  .feature-card { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.875rem; }
  .feature-card--accent {
    background: var(--charcoal);
    border-color: var(--charcoal);
    box-shadow: 5px 5px 0 var(--garnet);
  }

  .feature-icon {
    width: 2.75rem; height: 2.75rem;
    border: 2px solid var(--charcoal);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .feature-icon--garnet  { background: var(--garnet);   color: var(--white); border-color: var(--garnet-dark); }
  .feature-icon--charcoal { background: var(--charcoal); color: var(--alabaster); }
  .feature-icon--white   { background: var(--alabaster); color: var(--charcoal); border-color: var(--alabaster); }
  .feature-icon .material-symbols-outlined { font-size: 20px; }

  .feature-title { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--charcoal); }
  body.dark .feature-title { color: var(--alabaster); }
  .feature-body  { font-size: 0.875rem; color: var(--color-ink-muted); line-height: 1.65; }
  body.dark .feature-body { color: var(--color-ink-muted-dark); }

  /* ── Section helpers ── */
  .section-title { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; color: var(--charcoal); margin-bottom: 0.75rem; }
  body.dark .section-title { color: var(--alabaster); }
  .section-body  { font-size: 1rem; color: var(--color-ink-muted); max-width: 50ch; }
  body.dark .section-body { color: var(--color-ink-muted-dark); }
  .hide-sm { display: none; }
  @media (min-width: 640px) { .hide-sm { display: block; } }

  /* ── Steps ── */
  .steps-section {
    background: var(--charcoal);
    border-top: 2px solid var(--charcoal);
    border-bottom: 2px solid var(--charcoal);
    padding-block: 4rem;
  }
  @media (min-width: 1024px) { .steps-section { padding-block: 6rem; } }

  .steps-title { color: var(--alabaster); text-align: center; margin-bottom: 3rem; }

  .steps-grid { display: grid; gap: 2rem; }
  @media (min-width: 640px) { .steps-grid { grid-template-columns: repeat(3, 1fr); } }

  .step { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.75rem; }

  .step-icon {
    width: 3.5rem; height: 3.5rem;
    border: 2px solid currentColor;
    display: flex; align-items: center; justify-content: center;
  }
  .step-icon .material-symbols-outlined { font-size: 1.5rem; }
  .step-icon--1 { background: var(--garnet);  color: var(--white);    border-color: var(--garnet-dark); box-shadow: 4px 4px 0 var(--garnet-dark); }
  .step-icon--2 { background: var(--alabaster); color: var(--charcoal); border-color: var(--alabaster);  box-shadow: 4px 4px 0 var(--alabaster-dark); }
  .step-icon--3 { background: var(--charcoal-soft); color: var(--alabaster); border-color: var(--charcoal-soft); box-shadow: 4px 4px 0 var(--charcoal); }

  .step-num { font-family: var(--font-display); font-size: 4rem; font-weight: 800; color: rgba(230,225,222,0.08); line-height: 1; user-select: none; }
  .step-title { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; color: var(--alabaster); }
  .step-body  { font-size: 0.875rem; color: rgba(230,225,222,0.6); line-height: 1.65; }

  /* ── Testimonials ── */
  .testimonials-grid {
    display: grid; gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px)  { .testimonials-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .testimonials-grid { grid-template-columns: repeat(3, 1fr); } }

  .testimonial { padding: 1.5rem; }
  .testimonial--garnet {
    background: var(--garnet);
    border: 2px solid var(--garnet-dark);
    box-shadow: 5px 5px 0 var(--charcoal);
  }

  .testimonial-quote { font-size: 0.9375rem; font-style: italic; color: var(--color-ink-muted); line-height: 1.65; margin-bottom: 1.25rem; }
  body.dark .testimonial-quote { color: var(--color-ink-muted-dark); }

  .testimonial-footer { display: flex; align-items: center; gap: 0.75rem; }

  .avatar {
    width: 2.5rem; height: 2.5rem;
    border: 2px solid var(--charcoal);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-weight: 700; font-size: 0.8125rem;
    color: var(--white); flex-shrink: 0;
  }

  .testimonial-name { font-weight: 700; font-size: 0.875rem; color: var(--charcoal); display: block; }
  body.dark .testimonial-name { color: var(--alabaster); }
  .testimonial-role { font-size: 0.75rem; color: var(--color-ink-muted); }
  body.dark .testimonial-role { color: var(--color-ink-muted-dark); }

  /* ── Bottom CTA ── */
  .cta-section {
    background: var(--garnet);
    border-top: 2px solid var(--charcoal);
    padding-block: 4rem;
  }
  @media (min-width: 1024px) { .cta-section { padding-block: 5rem; } }

