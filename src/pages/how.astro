---
// src/pages/how.astro
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<Layout
  title="How It Works — visha | Buy & Sell in Minutes"
  description="Learn how visha works. Snap, list, chat, and get paid via M-Pesa — all from your phone in Nairobi."
  canonical="https://visha.app/how"
>

  <!-- Hero -->
  <section class="section-visha container-visha flex flex-col items-center gap-5 text-center pb-10" aria-labelledby="how-heading">
    <span class="tag tag-garnet">The App Guide</span>
    <h1 id="how-heading" class="text-[clamp(2rem,5vw,3.5rem)] font-extrabold text-charcoal dark:text-alabaster max-w-[20ch]">
      Buy and sell in Kenya —<br />
      <span class="highlight">from your phone.</span>
    </h1>
    <p class="text-base text-ink-muted dark:text-ink-muted-dark max-w-[55ch] leading-[1.7]">
      Whether you're a Gikomba vendor moving stock digitally, or a buyer hunting vintage gems — here's how visha works.
    </p>
  </section>

  <!-- Tab toggle -->
  <div class="flex justify-center px-5 mb-14" role="tablist" aria-label="Switch between seller and buyer view">
    <div class="bg-white border-2 border-charcoal shadow-[3px_3px_0_#000000] flex p-1.5 gap-2 dark:bg-card-dark dark:border-warm-dusk">
      <button id="tab-sellers" role="tab" aria-selected="true"
        class="tab inline-flex items-center gap-2 px-6 py-3 font-display font-bold text-sm cursor-pointer border-none bg-garnet text-white transition-all duration-150"
        onclick="switchTab('sellers')">
        <span class="material-symbols-outlined" style="font-size:18px">storefront</span>
        For Sellers
      </button>
      <button id="tab-buyers" role="tab" aria-selected="false"
        class="tab inline-flex items-center gap-2 px-6 py-3 font-display font-bold text-sm cursor-pointer border-none bg-transparent text-ink-muted transition-all duration-150 hover:text-charcoal dark:text-ink-muted-dark dark:hover:text-alabaster"
        onclick="switchTab('buyers')">
        <span class="material-symbols-outlined" style="font-size:18px">shopping_cart</span>
        For Buyers
      </button>
    </div>
  </div>

  <!-- Seller steps -->
  <div id="panel-sellers" class="container-visha pb-16" role="tabpanel">
    <div class="grid gap-6 lg:grid-cols-3">

      <article class="card-brutalist p-7 flex flex-col gap-4 relative">
        <div class="font-display text-[5rem] font-extrabold text-alabaster dark:text-warm-dusk leading-none absolute top-[-1rem] left-[-0.5rem] select-none pointer-events-none">1</div>
        <div class="icon-box icon-box--garnet w-16 h-16 hover:rotate-[-3deg] transition-transform duration-200"><span class="material-symbols-outlined" style="font-size:1.75rem">add_a_photo</span></div>
        <h3 class="font-display text-[1.375rem] font-bold text-charcoal dark:text-alabaster">Snap &amp; List</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Open the app, tap the + button, take a few photos, add a description and price. Your listing is live in under 60 seconds.</p>
        <div class="mt-auto w-full aspect-video bg-cover bg-center border-2 border-charcoal" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuAp-mOFFU8CaBlYmoTKEK4aDoKcWX6tr6fM7avfCrmSVEyfHeZDJp1iFR91qQI0gd8ryffgeVDO3TzIPM8sl1KfQzw-nFaTXHmzlXo8jQYPlajLPAqy5aVG9V6cMD8A1mcGa7xCsk25tlpcp6ehay0WP3DEFSFZybKnkHlQOskbhDPezhitci98SX75O0tVxmgfBf_L0cWEPDXkC6AA8flhiB2ygwdRSaeuwxi4KPMIYWcHGglbiRQQGmxTJQIwPEIYFnj5TT02kgg")' role="img" aria-label="Listing an item on visha"></div>
      </article>

      <article class="card-brutalist p-7 flex flex-col gap-4 relative">
        <div class="font-display text-[5rem] font-extrabold text-alabaster dark:text-warm-dusk leading-none absolute top-[-1rem] left-[-0.5rem] select-none pointer-events-none">2</div>
        <div class="icon-box icon-box--alabaster w-16 h-16 hover:rotate-[-3deg] transition-transform duration-200"><span class="material-symbols-outlined" style="font-size:1.75rem">forum</span></div>
        <h3 class="font-display text-[1.375rem] font-bold text-charcoal dark:text-alabaster">Chat &amp; Negotiate</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Buyers message you directly. Discuss price, condition, and pick-up — without sharing your personal number.</p>
        <div class="mt-auto bg-parchment border-2 border-charcoal p-4 flex flex-col gap-2 dark:bg-warm-dusk">
          <div class="bg-garnet text-white self-start px-3 py-1.5 text-xs font-bold max-w-[80%]">Is this still available?</div>
          <div class="bg-alabaster text-charcoal self-end px-3 py-1.5 text-xs font-bold max-w-[80%]">Yes! Great condition 👌</div>
          <div class="bg-garnet text-white self-start px-3 py-1.5 text-xs font-bold max-w-[80%]">Can we meet in CBD?</div>
        </div>
      </article>

      <article class="card-brutalist p-7 flex flex-col gap-4 relative">
        <div class="font-display text-[5rem] font-extrabold text-alabaster dark:text-warm-dusk leading-none absolute top-[-1rem] left-[-0.5rem] select-none pointer-events-none">3</div>
        <div class="icon-box icon-box--garnet w-16 h-16 hover:rotate-[-3deg] transition-transform duration-200"><span class="material-symbols-outlined" style="font-size:1.75rem">payments</span></div>
        <h3 class="font-display text-[1.375rem] font-bold text-charcoal dark:text-alabaster">Get Paid via M-Pesa</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">The buyer pays via M-Pesa inside the app. Funds are held safely until delivery is confirmed — then released to your wallet.</p>
        <div class="mt-auto bg-parchment border-2 border-charcoal p-5 flex flex-col items-center gap-2 aspect-video justify-center dark:bg-warm-dusk">
          <span class="material-symbols-outlined text-garnet" style="font-size:2.5rem;font-variation-settings:'FILL' 1">verified_user</span>
          <p class="text-[0.8125rem] font-bold text-charcoal dark:text-alabaster">Payment confirmed ✓</p>
          <p class="text-[0.6875rem] text-ink-muted">Funds released to your M-Pesa</p>
        </div>
      </article>

    </div>
  </div>

  <!-- Buyer steps -->
  <div id="panel-buyers" class="container-visha pb-16 hidden" role="tabpanel">
    <div class="grid gap-6 lg:grid-cols-3">

      <article class="card-brutalist p-7 flex flex-col gap-4 relative">
        <div class="font-display text-[5rem] font-extrabold text-alabaster dark:text-warm-dusk leading-none absolute top-[-1rem] left-[-0.5rem] select-none pointer-events-none">1</div>
        <div class="icon-box icon-box--garnet w-16 h-16"><span class="material-symbols-outlined" style="font-size:1.75rem">search</span></div>
        <h3 class="font-display text-[1.375rem] font-bold text-charcoal dark:text-alabaster">Browse &amp; Discover</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Search by category, style, or location. Filter by price and size. Save favourites and get notified when similar items drop.</p>
      </article>

      <article class="card-brutalist p-7 flex flex-col gap-4 relative">
        <div class="font-display text-[5rem] font-extrabold text-alabaster dark:text-warm-dusk leading-none absolute top-[-1rem] left-[-0.5rem] select-none pointer-events-none">2</div>
        <div class="icon-box icon-box--alabaster w-16 h-16"><span class="material-symbols-outlined" style="font-size:1.75rem">forum</span></div>
        <h3 class="font-display text-[1.375rem] font-bold text-charcoal dark:text-alabaster">Message the Seller</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Ask about size, condition, or arrange a local meetup — all inside the app. No numbers shared.</p>
      </article>

      <article class="card-brutalist p-7 flex flex-col gap-4 relative">
        <div class="font-display text-[5rem] font-extrabold text-alabaster dark:text-warm-dusk leading-none absolute top-[-1rem] left-[-0.5rem] select-none pointer-events-none">3</div>
        <div class="icon-box icon-box--garnet w-16 h-16"><span class="material-symbols-outlined" style="font-size:1.75rem">payments</span></div>
        <h3 class="font-display text-[1.375rem] font-bold text-charcoal dark:text-alabaster">Pay with M-Pesa</h3>
        <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Checkout with M-Pesa in one tap. Your money is held securely until you confirm the item arrived as described.</p>
      </article>

    </div>
  </div>

  <!-- Trust bar -->
  <section class="bg-charcoal border-y-2 border-charcoal py-10" aria-label="Trust indicators">
    <div class="container-visha grid gap-6 sm:grid-cols-3">
      <div class="flex items-center gap-4">
        <span class="material-symbols-outlined text-garnet shrink-0" style="font-size:2.25rem">shield</span>
        <div>
          <p class="font-bold text-alabaster text-[0.9375rem]">Verified Sellers</p>
          <p class="text-[0.8125rem] text-alabaster/60 mt-0.5">ID-checked, community rated</p>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <span class="material-symbols-outlined text-garnet shrink-0" style="font-size:2.25rem">payments</span>
        <div>
          <p class="font-bold text-alabaster text-[0.9375rem]">Escrow Payments</p>
          <p class="text-[0.8125rem] text-alabaster/60 mt-0.5">Your money is always protected</p>
        </div>
      </div>
      <div class="flex items-center gap-4">
        <span class="material-symbols-outlined text-garnet shrink-0" style="font-size:2.25rem">support_agent</span>
        <div>
          <p class="font-bold text-alabaster text-[0.9375rem]">Nairobi Support</p>
          <p class="text-[0.8125rem] text-alabaster/60 mt-0.5">Real people, fast responses</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-garnet border-t-2 border-charcoal py-16 pb-20" aria-labelledby="how-cta">
    <div class="container-visha flex flex-col items-center text-center gap-5">
      <h2 id="how-cta" class="text-[clamp(1.75rem,4vw,3rem)] font-extrabold text-white">Ready to start?</h2>
      <p class="text-base text-alabaster/80 max-w-[42ch]">Sign up for early access and be among the first to buy and sell on visha in Nairobi.</p>
      <div class="max-w-[28rem] w-full [&_.waitlist-success]:text-alabaster">
        <WaitlistForm id="how" dark={true} />
      </div>
    </div>
  </section>

</Layout>

<script>
  function switchTab(tab: string) {
    const sellers = document.getElementById('panel-sellers')!;
    const buyers  = document.getElementById('panel-buyers')!;
    const btnS    = document.getElementById('tab-sellers')!;
    const btnB    = document.getElementById('tab-buyers')!;

    if (tab === 'sellers') {
      sellers.classList.remove('hidden'); buyers.classList.add('hidden');
      btnS.classList.add('!bg-garnet', '!text-white'); btnS.classList.remove('bg-transparent', 'text-ink-muted');
      btnB.classList.remove('!bg-garnet', '!text-white'); btnB.classList.add('bg-transparent', 'text-ink-muted');
      btnS.setAttribute('aria-selected','true');
      btnB.setAttribute('aria-selected','false');
    } else {
      buyers.classList.remove('hidden'); sellers.classList.add('hidden');
      btnB.classList.add('!bg-garnet', '!text-white'); btnB.classList.remove('bg-transparent', 'text-ink-muted');
      btnS.classList.remove('!bg-garnet', '!text-white'); btnS.classList.add('bg-transparent', 'text-ink-muted');
      btnB.setAttribute('aria-selected','true');
      btnS.setAttribute('aria-selected','false');
    }
  }
  (window as any).switchTab = switchTab;
</script>
