---
// src/pages/blog.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="The Fashion Edit — visha Blog"
  description="Stories on Kenyan streetwear, vintage treasures, sustainable fashion, and the rise of thrift culture in Nairobi."
  canonical="https://visha.app/blog"
>

  <!-- Hero -->
  <section class="section container blog-hero" aria-labelledby="blog-heading">
    <h1 id="blog-heading" class="blog-title">The Fashion Edit</h1>
    <p class="blog-subtitle">Exploring the pulse of Kenyan style, vintage treasures, and the rise of sustainable culture in the Green City in the Sun.</p>
  </section>

  <!-- Categories -->
  <nav class="container categories-nav" aria-label="Blog categories">
    <div class="categories-scroll">
      <a href="#" class="cat cat--active">All Posts</a>
      <a href="#" class="cat">Streetwear</a>
      <a href="#" class="cat">Vintage</a>
      <a href="#" class="cat">Sustainable</a>
      <a href="#" class="cat">Local Labels</a>
    </div>
  </nav>

  <!-- Featured article -->
  <section class="container featured-wrap" aria-labelledby="featured-heading">
    <article class="card featured-article">
      <div class="featured-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDoYBiRzrotXyoGqnzmkWO5mJSkvsVeV1wbmZk79_x8gLvxKyUjxG0BZYbsTcJUCP-sVPhklqmr309M0e6ZxzGeS5n52mS8yHAKzos1SkYfRww5aMCkw9COILddSNT4vkQBpFahkjKj5kuhjeq5m3i0euUL5ydL9fD15k6Alf9zTn4eToJ2xAjJIEOpdtVGT47HzKj1l1jhZ0Y1jaXmVHLU5zXKuC2hvnkYvqDOQynmkvGveD69G0N-dWQzL53Am4h5w3L2Eb9HMc8")' role="img" aria-label="Modern Kenyan streetwear model"></div>
      <div class="featured-body">
        <span class="tag tag-charcoal">Streetwear</span>
        <h2 id="featured-heading" class="featured-title">Kenyan Streetwear Trends: Beyond the Aesthetic</h2>
        <p class="featured-excerpt">From oversized silhouettes to tribal print fusions, see how Nairobi's youth are redefining modern identity through bold style choices.</p>
        <footer class="featured-footer">
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuC5wXOCetqdmOBEih_TefJmWL4-nD-1vJQ5HMYiWOW82hV2jkemL2FtY8k8wCMQPwD8bz6NT44p_fWgLY4phqM9j5_6bz4PkfaoAGKdQh0aT0opqzb-htKqA8sv--Q2CMNU2o7l5LqvCcAixzGCY-CwC7dzM4kuJOjotFHFWRNcCaYnJPf0x72subEuJTiTKmwZuVEHKQ50W8H8WPlUbuw5NehOKx9SK2iK6josAeoWHucx7sl7cYbuz7RtujV1af1038hvllJb0Gg"
            alt="Wanjiku Kamau" class="author-avatar" loading="lazy" />
          <div>
            <p class="author-name">Wanjiku Kamau</p>
            <time class="post-meta" datetime="2023-10-12">5 min read · Oct 12, 2023</time>
          </div>
          <a href="#" class="btn btn-primary" style="margin-left:auto">
            Read More
            <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
          </a>
        </footer>
      </div>
    </article>
  </section>

  <!-- Latest stories grid -->
  <section class="section container" aria-labelledby="latest-heading">
    <h2 id="latest-heading" class="latest-heading">
      <span class="material-symbols-outlined" style="color:var(--garnet)">auto_awesome</span>
      Latest Stories
    </h2>
    <div class="posts-grid">

      <article class="card post-card">
        <div class="post-img-wrap">
          <div class="post-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDuFfF6kCtk0imm5wS2u1kkKrw7okew5LyYZQMIL3netV50EKxsdcTIbZDy3VTq_9EHW8z0nGqhmtXVSbUnaDuQZ913afYbbKlPiRx6XYKOTgiCfwGBy-ZDZuNj-uKrtSnvzB3VzmpgtRPii89n4hsJPlYPkxjkUNLPMTM_4wa7rvfwFMPul5dEdsTSeeOHWscOIlu2AtG70lKHXyoT6CoZlODevQrpG23G81fZc5UGiRvnekIJBe-53hLe1bXSUH2BfxyYtcR8uuw")'></div>
          <span class="post-tag">Vintage</span>
        </div>
        <div class="post-body">
          <h3 class="post-title">How to Spot Vintage Gems in Gikomba</h3>
          <p class="post-excerpt">The ultimate guide to navigating East Africa's largest open-air market for high-end labels and unique 90s finds.</p>
          <footer class="post-footer">
            <time class="post-meta" datetime="2023-10-10">Oct 10, 2023</time>
            <a href="#" class="post-link">Read story <span class="material-symbols-outlined" style="font-size:15px">north_east</span></a>
          </footer>
        </div>
      </article>

      <article class="card post-card">
        <div class="post-img-wrap">
          <div class="post-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDkk77Cd7sm6GaxfJBrehekp7H7wQFIRMfGgtt9lAu2Le4TYBOBDEdGK29jXEgw4zDgL0xC83FjoomwuYiwlhxFmm5TzSmKdNM9zpjYZMfWGXwNzBujHP-Sey2X7RTmEkGTeLq8BUiXgxxUsheBU-9rv9QMBsRkPHLO6v3X4tHReoaoDvVoT1YSDhuJnDXwL-GQvo3Cwj7oGSwfRdV40RKa_ov2YeSyVLnnnzJgKXCXYyRNnxslrCS9e3wSZCpiBuiSncnT-gVsMuo")'></div>
          <span class="post-tag">Sustainability</span>
        </div>
        <div class="post-body">
          <h3 class="post-title">Sustainable Fashion in Nairobi</h3>
          <p class="post-excerpt">Meet the local designers transforming recycled materials into runway-ready couture, leading the slow fashion movement.</p>
          <footer class="post-footer">
            <time class="post-meta" datetime="2023-10-08">Oct 8, 2023</time>
            <a href="#" class="post-link">Read story <span class="material-symbols-outlined" style="font-size:15px">north_east</span></a>
          </footer>
        </div>
      </article>

      <article class="card post-card">
        <div class="post-img-wrap">
          <div class="post-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuD-Yxup1LA46Tbqgcxq4luOkaSjTtvgNRN9-Qzqf-NZ4x8JNBPt-IQc7xj5XyjpguBzkiAAV0Qawlv4BniC6LAPfjqwUqLs5J2_2VW6vY0MCz_iuEJALfe-jGSnJqSjyYjEHIRMaY8vA8UXele0jBI9Tl8Swp4a5I-FtEt5iuB6TU9D5HHOGCaAeEPf2WFyOcsHha4s1IZYr0BIgGWJ-RnlbEj6CUCrYMeDyyvSa1krnQFIO2aAAVzpbhZzcK1n0U_yonSdyabZ1-o")'></div>
          <span class="post-tag">Local Labels</span>
        </div>
        <div class="post-body">
          <h3 class="post-title">The Modern Maasai: Reimagined Patterns</h3>
          <p class="post-excerpt">How traditional shuka patterns are finding their way into high-fashion menswear and luxury accessories.</p>
          <footer class="post-footer">
            <time class="post-meta" datetime="2023-10-05">Oct 5, 2023</time>
            <a href="#" class="post-link">Read story <span class="material-symbols-outlined" style="font-size:15px">north_east</span></a>
          </footer>
        </div>
      </article>

    </div>
  </section>

  <!-- Newsletter -->
  <section class="newsletter-section" aria-labelledby="newsletter-heading">
    <div class="container newsletter-inner">
      <h2 id="newsletter-heading" class="newsletter-title">Stay Ahead of the Curve</h2>
      <p class="newsletter-body">Join the weekly edit of Nairobi's best style — delivered to your inbox.</p>
      <form class="newsletter-form" onsubmit="handleNewsletter(event)">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input id="newsletter-email" type="email" placeholder="Your email address" required class="input newsletter-input" />
        <button type="submit" class="btn btn-alabaster">Subscribe</button>
      </form>
      <p id="newsletter-success" class="newsletter-success hidden">
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">check_circle</span>
        Welcome to the edit!
      </p>
      <p class="newsletter-note">No spam. Only curated inspiration.</p>
    </div>
  </section>

</Layout>

<script>
  function handleNewsletter(e: Event) {
    e.preventDefault();
    (e.target as HTMLElement).classList.add('hidden');
    document.getElementById('newsletter-success')!.classList.remove('hidden');
  }
  (window as any).handleNewsletter = handleNewsletter;
</script>

<style>
  /* Hero */
  .blog-hero { padding-bottom: 2rem; }
  .blog-title { font-size: clamp(3rem, 8vw, 5.5rem); font-weight: 800; color: var(--charcoal); margin-bottom: 1rem; }
  body.dark .blog-title { color: var(--alabaster); }
  .blog-subtitle { font-size: 1.0625rem; color: var(--garnet); font-weight: 600; max-width: 52ch; line-height: 1.65; }
  body.dark .blog-subtitle { color: var(--garnet-soft); }

  /* Categories */
  .categories-nav { margin-bottom: 3rem; border-bottom: 2px solid var(--charcoal); overflow-x: auto; }
  body.dark .categories-nav { border-color: var(--charcoal-soft); }
  .categories-scroll { display: flex; min-width: max-content; }
  .cat {
    display: block; padding: 1rem 1.5rem;
    font-size: 0.875rem; font-weight: 700; font-family: var(--font-display);
    color: var(--color-ink-muted); white-space: nowrap;
    border-bottom: 3px solid transparent; transition: all 0.15s;
  }
  body.dark .cat { color: var(--color-ink-muted-dark); }
  .cat:hover { color: var(--charcoal); }
  body.dark .cat:hover { color: var(--alabaster); }
  .cat--active { color: var(--charcoal); border-bottom-color: var(--garnet); }
  body.dark .cat--active { color: var(--alabaster); }

  /* Featured */
  .featured-wrap { margin-bottom: 4rem; }
  .featured-article { display: grid; overflow: hidden; }
  @media (min-width: 768px) { .featured-article { grid-template-columns: 1fr 1fr; } }

  .featured-img {
    aspect-ratio: 4/3;
    background-size: cover; background-position: center;
    border-bottom: 2px solid var(--charcoal);
  }
  @media (min-width: 768px) { .featured-img { aspect-ratio: auto; border-bottom: none; border-right: 2px solid var(--charcoal); } }

  .featured-body { padding: 2rem 2.25rem; display: flex; flex-direction: column; gap: 1.25rem; justify-content: center; }
  .featured-title { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: var(--charcoal); line-height: 1.15; }
  body.dark .featured-title { color: var(--alabaster); }
  .featured-excerpt { font-size: 0.9375rem; color: var(--color-ink-muted); line-height: 1.65; }
  body.dark .featured-excerpt { color: var(--color-ink-muted-dark); }
  .featured-footer { display: flex; align-items: center; gap: 0.875rem; flex-wrap: wrap; }
  .author-avatar { width: 2.5rem; height: 2.5rem; object-fit: cover; border: 2px solid var(--charcoal); flex-shrink: 0; }
  .author-name { font-weight: 700; font-size: 0.875rem; color: var(--charcoal); }
  body.dark .author-name { color: var(--alabaster); }
  .post-meta { font-size: 0.75rem; color: var(--color-ink-muted); display: block; }
  body.dark .post-meta { color: var(--color-ink-muted-dark); }

  /* Latest posts grid */
  .latest-heading { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; color: var(--charcoal); margin-bottom: 2rem; }
  body.dark .latest-heading { color: var(--alabaster); }

  .posts-grid { display: grid; gap: 1.5rem; }
  @media (min-width: 640px)  { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .posts-grid { grid-template-columns: repeat(3, 1fr); } }

  .post-card { display: flex; flex-direction: column; overflow: hidden; }
  .post-img-wrap { position: relative; aspect-ratio: 1; overflow: hidden; border-bottom: 2px solid var(--charcoal); }
  .post-img { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform 0.4s; }
  .post-card:hover .post-img { transform: scale(1.04); }
  .post-tag { position: absolute; top: 0.75rem; left: 0.75rem; background: var(--garnet); color: var(--white); border: 2px solid var(--garnet-dark); padding: 0.2rem 0.6rem; font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; }

  .post-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.625rem; }
  .post-title { font-family: var(--font-display); font-size: 1.0625rem; font-weight: 700; color: var(--charcoal); line-height: 1.25; }
  body.dark .post-title { color: var(--alabaster); }
  .post-excerpt { font-size: 0.8125rem; color: var(--color-ink-muted); line-height: 1.65; flex: 1; }
  body.dark .post-excerpt { color: var(--color-ink-muted-dark); }
  .post-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 0.75rem; border-top: 1px solid rgba(37,41,28,0.1); }
  body.dark .post-footer { border-color: rgba(230,225,222,0.1); }
  .post-link { font-size: 0.8125rem; font-weight: 700; color: var(--garnet); display: inline-flex; align-items: center; gap: 0.25rem; transition: gap 0.15s; }
  .post-link:hover { gap: 0.5rem; }

  /* Newsletter */
  .newsletter-section { background: var(--charcoal); border-top: 2px solid var(--charcoal); padding-block: 4rem 5rem; }
  .newsletter-inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1.25rem; }
  .newsletter-title { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; color: var(--alabaster); }
  .newsletter-body  { font-size: 1rem; color: rgba(230,225,222,0.7); max-width: 40ch; }
  .newsletter-form  { display: flex; flex-direction: column; gap: 0.625rem; max-width: 26rem; width: 100%; }
  @media (min-width: 480px) { .newsletter-form { flex-direction: row; } }
  .newsletter-input { flex: 1; }
  .newsletter-form.hidden { display: none; }
  .newsletter-success { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; color: var(--alabaster); }
  .newsletter-success.hidden { display: none; }
  .newsletter-note { font-size: 0.6875rem; color: rgba(230,225,222,0.4); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600; }

  .sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0 }
</style>
