---
// src/pages/blog.astro
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="The Fashion Edit — visha Blog"
  description="Stories on Kenyan streetwear, vintage treasures, sustainable fashion, and the rise of thrift culture in Nairobi."
  canonical="https://visha.app/blog"
>

  <!-- Hero -->
  <section class="section-visha container-visha pb-8" aria-labelledby="blog-heading">
    <h1 id="blog-heading" class="text-[clamp(3rem,8vw,5.5rem)] font-extrabold text-charcoal dark:text-alabaster mb-4">The Fashion Edit</h1>
    <p class="text-[1.0625rem] text-garnet font-semibold max-w-[52ch] leading-[1.65] dark:text-garnet-soft">Exploring the pulse of Kenyan style, vintage treasures, and the rise of sustainable culture in the Green City in the Sun.</p>
  </section>

  <!-- Categories -->
  <nav class="container-visha mb-12 border-b-2 border-charcoal overflow-x-auto dark:border-warm-dusk" aria-label="Blog categories">
    <div class="flex min-w-max">
      <a href="#" class="block px-6 py-4 text-sm font-bold font-display text-charcoal whitespace-nowrap border-b-[3px] border-garnet dark:text-alabaster">All Posts</a>
      <a href="#" class="block px-6 py-4 text-sm font-bold font-display text-ink-muted whitespace-nowrap border-b-[3px] border-transparent transition-all hover:text-charcoal dark:text-ink-muted-dark dark:hover:text-alabaster">Streetwear</a>
      <a href="#" class="block px-6 py-4 text-sm font-bold font-display text-ink-muted whitespace-nowrap border-b-[3px] border-transparent transition-all hover:text-charcoal dark:text-ink-muted-dark dark:hover:text-alabaster">Vintage</a>
      <a href="#" class="block px-6 py-4 text-sm font-bold font-display text-ink-muted whitespace-nowrap border-b-[3px] border-transparent transition-all hover:text-charcoal dark:text-ink-muted-dark dark:hover:text-alabaster">Sustainable</a>
      <a href="#" class="block px-6 py-4 text-sm font-bold font-display text-ink-muted whitespace-nowrap border-b-[3px] border-transparent transition-all hover:text-charcoal dark:text-ink-muted-dark dark:hover:text-alabaster">Local Labels</a>
    </div>
  </nav>

  <!-- Featured article -->
  <section class="container-visha mb-16" aria-labelledby="featured-heading">
    <article class="card-brutalist grid overflow-hidden md:grid-cols-2">
      <div
        class="aspect-[4/3] bg-cover bg-center border-b-2 border-charcoal md:border-b-0 md:border-r-2 dark:border-warm-dusk"
        style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDoYBiRzrotXyoGqnzmkWO5mJSkvsVeV1wbmZk79_x8gLvxKyUjxG0BZYbsTcJUCP-sVPhklqmr309M0e6ZxzGeS5n52mS8yHAKzos1SkYfRww5aMCkw9COILddSNT4vkQBpFahkjKj5kuhjeq5m3i0euUL5ydL9fD15k6Alf9zTn4eToJ2xAjJIEOpdtVGT47HzKj1l1jhZ0Y1jaXmVHLU5zXKuC2hvnkYvqDOQynmkvGveD69G0N-dWQzL53Am4h5w3L2Eb9HMc8")'
        role="img" aria-label="Modern Kenyan streetwear model"
      ></div>
      <div class="p-8 lg:p-9 flex flex-col gap-5 justify-center">
        <span class="tag tag-charcoal">Streetwear</span>
        <h2 id="featured-heading" class="text-[clamp(1.5rem,3vw,2rem)] font-extrabold text-charcoal dark:text-alabaster leading-[1.15]">Kenyan Streetwear Trends: Beyond the Aesthetic</h2>
        <p class="text-[0.9375rem] text-ink-muted dark:text-ink-muted-dark leading-[1.65]">From oversized silhouettes to tribal print fusions, see how Nairobi's youth are redefining modern identity through bold style choices.</p>
        <footer class="flex items-center gap-3.5 flex-wrap">
          <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuC5wXOCetqdmOBEih_TefJmWL4-nD-1vJQ5HMYiWOW82hV2jkemL2FtY8k8wCMQPwD8bz6NT44p_fWgLY4phqM9j5_6bz4PkfaoAGKdQh0aT0opqzb-htKqA8sv--Q2CMNU2o7l5LqvCcAixzGCY-CwC7dzM4kuJOjotFHFWRNcCaYnJPf0x72subEuJTiTKmwZuVEHKQ50W8H8WPlUbuw5NehOKx9SK2iK6josAeoWHucx7sl7cYbuz7RtujV1af1038hvllJb0Gg"
            alt="Wanjiku Kamau" class="w-10 h-10 object-cover border-2 border-charcoal shrink-0" loading="lazy" />
          <div>
            <p class="font-bold text-sm text-charcoal dark:text-alabaster">Wanjiku Kamau</p>
            <time class="text-xs text-ink-muted dark:text-ink-muted-dark block" datetime="2023-10-12">5 min read · Oct 12, 2023</time>
          </div>
          <a href="#" class="btn-primary ml-auto">
            Read More
            <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
          </a>
        </footer>
      </div>
    </article>
  </section>

  <!-- Latest stories grid -->
  <section class="section-visha container-visha" aria-labelledby="latest-heading">
    <h2 id="latest-heading" class="font-display text-[1.25rem] font-bold flex items-center gap-2 text-charcoal dark:text-alabaster mb-8">
      <span class="material-symbols-outlined text-garnet">auto_awesome</span>
      Latest Stories
    </h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

      <article class="card-brutalist flex flex-col overflow-hidden">
        <div class="relative aspect-square overflow-hidden border-b-2 border-charcoal dark:border-warm-dusk">
          <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 hover:scale-[1.04]"
            style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDuFfF6kCtk0imm5wS2u1kkKrw7okew5LyYZQMIL3netV50EKxsdcTIbZDy3VTq_9EHW8z0nGqhmtXVSbUnaDuQZ913afYbbKlPiRx6XYKOTgiCfwGBy-ZDZuNj-uKrtSnvzB3VzmpgtRPii89n4hsJPlYPkxjkUNLPMTM_4wa7rvfwFMPul5dEdsTSeeOHWscOIlu2AtG70lKHXyoT6CoZlODevQrpG23G81fZc5UGiRvnekIJBe-53hLe1bXSUH2BfxyYtcR8uuw")'></div>
          <span class="absolute top-3 left-3 bg-garnet text-white border-2 border-mahogany px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.07em]">Vintage</span>
        </div>
        <div class="p-5 flex-1 flex flex-col gap-2.5">
          <h3 class="font-display text-[1.0625rem] font-bold text-charcoal dark:text-alabaster leading-[1.25]">How to Spot Vintage Gems in Gikomba</h3>
          <p class="text-[0.8125rem] text-ink-muted dark:text-ink-muted-dark leading-[1.65] flex-1">The ultimate guide to navigating East Africa's largest open-air market for high-end labels and unique 90s finds.</p>
          <footer class="flex items-center justify-between mt-auto pt-3 border-t border-charcoal/10 dark:border-alabaster/10">
            <time class="text-xs text-ink-muted dark:text-ink-muted-dark" datetime="2023-10-10">Oct 10, 2023</time>
            <a href="#" class="text-[0.8125rem] font-bold text-garnet inline-flex items-center gap-1 transition-[gap] duration-150 hover:gap-2">Read story <span class="material-symbols-outlined" style="font-size:15px">north_east</span></a>
          </footer>
        </div>
      </article>

      <article class="card-brutalist flex flex-col overflow-hidden">
        <div class="relative aspect-square overflow-hidden border-b-2 border-charcoal dark:border-warm-dusk">
          <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 hover:scale-[1.04]"
            style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuDkk77Cd7sm6GaxfJBrehekp7H7wQFIRMfGgtt9lAu2Le4TYBOBDEdGK29jXEgw4zDgL0xC83FjoomwuYiwlhxFmm5TzSmKdNM9zpjYZMfWGXwNzBujHP-Sey2X7RTmEkGTeLq8BUiXgxxUsheBU-9rv9QMBsRkPHLO6v3X4tHReoaoDvVoT1YSDhuJnDXwL-GQvo3Cwj7oGSwfRdV40RKa_ov2YeSyVLnnnzJgKXCXYyRNnxslrCS9e3wSZCpiBuiSncnT-gVsMuo")'></div>
          <span class="absolute top-3 left-3 bg-garnet text-white border-2 border-mahogany px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.07em]">Sustainability</span>
        </div>
        <div class="p-5 flex-1 flex flex-col gap-2.5">
          <h3 class="font-display text-[1.0625rem] font-bold text-charcoal dark:text-alabaster leading-[1.25]">Sustainable Fashion in Nairobi</h3>
          <p class="text-[0.8125rem] text-ink-muted dark:text-ink-muted-dark leading-[1.65] flex-1">Meet the local designers transforming recycled materials into runway-ready couture, leading the slow fashion movement.</p>
          <footer class="flex items-center justify-between mt-auto pt-3 border-t border-charcoal/10 dark:border-alabaster/10">
            <time class="text-xs text-ink-muted dark:text-ink-muted-dark" datetime="2023-10-08">Oct 8, 2023</time>
            <a href="#" class="text-[0.8125rem] font-bold text-garnet inline-flex items-center gap-1 transition-[gap] duration-150 hover:gap-2">Read story <span class="material-symbols-outlined" style="font-size:15px">north_east</span></a>
          </footer>
        </div>
      </article>

      <article class="card-brutalist flex flex-col overflow-hidden">
        <div class="relative aspect-square overflow-hidden border-b-2 border-charcoal dark:border-warm-dusk">
          <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 hover:scale-[1.04]"
            style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuD-Yxup1LA46Tbqgcxq4luOkaSjTtvgNRN9-Qzqf-NZ4x8JNBPt-IQc7xj5XyjpguBzkiAAV0Qawlv4BniC6LAPfjqwUqLs5J2_2VW6vY0MCz_iuEJALfe-jGSnJqSjyYjEHIRMaY8vA8UXele0jBI9Tl8Swp4a5I-FtEt5iuB6TU9D5HHOGCaAeEPf2WFyOcsHha4s1IZYr0BIgGWJ-RnlbEj6CUCrYMeDyyvSa1krnQFIO2aAAVzpbhZzcK1n0U_yonSdyabZ1-o")'></div>
          <span class="absolute top-3 left-3 bg-garnet text-white border-2 border-mahogany px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.07em]">Local Labels</span>
        </div>
        <div class="p-5 flex-1 flex flex-col gap-2.5">
          <h3 class="font-display text-[1.0625rem] font-bold text-charcoal dark:text-alabaster leading-[1.25]">The Modern Maasai: Reimagined Patterns</h3>
          <p class="text-[0.8125rem] text-ink-muted dark:text-ink-muted-dark leading-[1.65] flex-1">How traditional shuka patterns are finding their way into high-fashion menswear and luxury accessories.</p>
          <footer class="flex items-center justify-between mt-auto pt-3 border-t border-charcoal/10 dark:border-alabaster/10">
            <time class="text-xs text-ink-muted dark:text-ink-muted-dark" datetime="2023-10-05">Oct 5, 2023</time>
            <a href="#" class="text-[0.8125rem] font-bold text-garnet inline-flex items-center gap-1 transition-[gap] duration-150 hover:gap-2">Read story <span class="material-symbols-outlined" style="font-size:15px">north_east</span></a>
          </footer>
        </div>
      </article>

    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-charcoal border-t-2 border-charcoal py-16 pb-20" aria-labelledby="newsletter-heading">
    <div class="container-visha flex flex-col items-center text-center gap-5">
      <h2 id="newsletter-heading" class="text-[clamp(1.75rem,4vw,2.75rem)] font-extrabold text-alabaster">Stay Ahead of the Curve</h2>
      <p class="text-base text-alabaster/70 max-w-[40ch]">Join the weekly edit of Nairobi's best style — delivered to your inbox.</p>
      <form class="newsletter-form flex flex-col gap-2.5 max-w-[26rem] w-full" onsubmit="handleNewsletter(event)">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input id="newsletter-email" type="email" placeholder="Your email address" required class="input-brutalist flex-1" />
        <button type="submit" class="btn-alabaster">Subscribe</button>
      </form>
      <p id="newsletter-success" class="hidden items-center gap-2 font-bold text-alabaster">
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">check_circle</span>
        Welcome to the edit!
      </p>
      <p class="text-[11px] text-alabaster/40 uppercase tracking-widest font-semibold">No spam. Only curated inspiration.</p>
    </div>
  </section>

</Layout>

<script>
  function handleNewsletter(e: Event) {
    e.preventDefault();
    const form = e.target as HTMLElement;
    form.classList.add('hidden');
    const success = document.getElementById('newsletter-success')!;
    success.classList.remove('hidden');
    success.style.display = 'flex';
  }
  (window as any).handleNewsletter = handleNewsletter;
</script>

<style>
  /* Newsletter form: flex row on wider screens */
  .newsletter-form:not(.hidden) { display: flex; }
  @media (min-width: 480px) { .newsletter-form:not(.hidden) { flex-direction: row; } }
</style>
