---
// src/pages/blog.astro
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// Fetch blog entries
const blogEntries = await getCollection('blog');
const sortedPosts = blogEntries.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Helper function to turn a Content Layer entry ID into a clean URL slug
const getSlugFromId = (id: string) => id.replace(/\.mdx?$/, '');

// Extract all unique tags
const allTags = Array.from(new Set(blogEntries.flatMap(post => post.data.tags || []))).filter(Boolean);

// Fallback image when no thumbnail is set in frontmatter
const FALLBACK_IMAGE = "/images/IMG_4277.webp";

function getPostImage(thumbnail?: string) {
  return thumbnail || FALLBACK_IMAGE;
}
---

<Layout
  title="The Fashion Edit — visha Blog"
  description="Stories on Kenyan streetwear, vintage treasures, sustainable fashion, and the rise of thrift culture in Nairobi."
  canonical="https://visha.app/blog"
>

  <!-- Hero -->
  <section class="section-visha container-visha pb-4" aria-labelledby="blog-heading">
    <h1 id="blog-heading" class="text-[clamp(3rem,8vw,5.5rem)] font-extrabold text-charcoal dark:text-alabaster mb-4">The Fashion Edit</h1>
    <p class="text-[1.0625rem] text-garnet font-semibold max-w-[52ch] leading-[1.65] dark:text-garnet-soft">Exploring the pulse of Kenyan style, vintage treasures, and the rise of sustainable culture in the Green City in the Sun.</p>
  </section>

  <!-- Search Bar -->
  <div class="container-visha mb-8 max-w-xl mx-auto">
    <div class="relative">
      <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-ink-muted dark:text-ink-muted-dark pointer-events-none" style="font-size:20px">search</span>
      <input 
        id="blog-search" 
        type="search" 
        placeholder="Search stories, topics, tags..." 
        class="input-brutalist pl-11 py-4 text-base"
      />
    </div>
  </div>

  <!-- Interactive Categories / Tags -->
  <nav class="container-visha mb-12 border-b-2 border-charcoal overflow-x-auto dark:border-warm-dusk" aria-label="Blog categories">
    <div class="flex min-w-max gap-2 pb-3">
      <button 
        data-tag="all" 
        class="tag-filter-btn px-6 py-3 text-sm font-bold font-display cursor-pointer transition-all bg-garnet text-white border-2 border-charcoal shadow-[2px_2px_0_#28231E] dark:border-alabaster"
      >
        All Posts
      </button>
      {allTags.map((tag) => (
        <button 
          data-tag={tag} 
          class="tag-filter-btn px-6 py-3 text-sm font-bold font-display cursor-pointer transition-all bg-white text-charcoal border-2 border-charcoal/20 dark:bg-card-dark dark:text-alabaster dark:border-warm-dusk uppercase"
        >
          {tag}
        </button>
      ))}
    </div>
  </nav>

  <!-- Featured article -->
  {sortedPosts.length > 0 && (
    <section id="featured-section" class="container-visha mb-16">
      <article class="card-brutalist grid overflow-hidden md:grid-cols-2">
        <div
          class="aspect-[4/3] bg-cover bg-center border-b-2 border-charcoal md:border-b-0 md:border-r-2 dark:border-warm-dusk"
          style={`background-image: url("${getPostImage(sortedPosts[0].data.thumbnail)}")`}
          role="img" 
          aria-label={sortedPosts[0].data.title}
        ></div>
        <div class="p-8 lg:p-9 flex flex-col gap-5 justify-center">
          {sortedPosts[0].data.tags && sortedPosts[0].data.tags.length > 0 && (
            <span class="tag tag-charcoal self-start uppercase">{sortedPosts[0].data.tags[0]}</span>
          )}
          <h2 class="text-[clamp(1.5rem,3vw,2rem)] font-extrabold text-charcoal dark:text-alabaster leading-[1.15]">
            <a href={`/blog/${getSlugFromId(sortedPosts[0].id)}`} class="hover:underline">
              {sortedPosts[0].data.title}
            </a>
          </h2>
          <p class="text-[0.9375rem] text-ink-muted dark:text-ink-muted-dark leading-[1.65]">
            {sortedPosts[0].data.description || 'Discover the latest trends and stories from our team.'}
          </p>
          <footer class="flex items-center gap-3.5 flex-wrap">
            <div class="w-10 h-10 border-2 border-charcoal bg-garnet text-white font-display font-extrabold flex items-center justify-center text-sm shrink-0">
              {sortedPosts[0].data.author ? sortedPosts[0].data.author.charAt(0).toUpperCase() : 'V'}
            </div>
            <div>
              <p class="font-bold text-sm text-charcoal dark:text-alabaster leading-none mb-1">{sortedPosts[0].data.author || 'visha Team'}</p>
              <time class="text-xs text-ink-muted dark:text-ink-muted-dark block" datetime={sortedPosts[0].data.pubDate.toISOString()}>
                {sortedPosts[0].data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                &middot; {Math.max(1, Math.round(sortedPosts[0].body ? sortedPosts[0].body.split(/\s+/).length / 200 : 1))} min read
              </time>
            </div>
            <a href={`/blog/${getSlugFromId(sortedPosts[0].id)}`} class="btn-primary ml-auto text-xs">
              Read Story
              <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
            </a>
          </footer>
        </div>
      </article>
    </section>
  )}

  <!-- Latest stories grid -->
  <section class="section-visha container-visha pt-4" aria-labelledby="latest-heading">
    <h2 id="latest-heading" class="font-display text-[1.25rem] font-bold flex items-center gap-2 text-charcoal dark:text-alabaster mb-8">
      <span class="material-symbols-outlined text-garnet">auto_awesome</span>
      Latest Stories
    </h2>

    <!-- Empty State -->
    <div id="no-results" class="hidden text-center py-16 border-2 border-dashed border-charcoal/20 dark:border-alabaster/20 card-brutalist p-8 my-8">
      <span class="material-symbols-outlined text-4xl text-garnet mb-3">search_off</span>
      <h3 class="font-display font-bold text-xl mb-2 text-charcoal dark:text-alabaster">No stories found</h3>
      <p class="text-ink-muted dark:text-ink-muted-dark max-w-md mx-auto">We couldn't find any articles matching your search query. Try clearing filters or searching for something else!</p>
      <button id="clear-search-btn" class="btn-ghost mt-6 text-sm">Clear Search & Filters</button>
    </div>

    <div id="posts-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sortedPosts.map((post, index) => {
        const postTags = post.data.tags || [];
        const titleLower = post.data.title.toLowerCase();
        const descLower = (post.data.description || "").toLowerCase();
        const authorLower = (post.data.author || "").toLowerCase();
        const searchString = `${titleLower} ${descLower} ${authorLower} ${postTags.join(" ").toLowerCase()}`;
        
        return (
          <article 
            class="blog-post-card card-brutalist flex flex-col overflow-hidden" 
            data-search-content={searchString}
            data-tags={JSON.stringify(postTags)}
            data-is-featured={index === 0 ? "true" : "false"}
            style={index === 0 ? "display: none;" : ""}
          >
            <div class="relative aspect-square overflow-hidden border-b-2 border-charcoal dark:border-warm-dusk">
              <div class="absolute inset-0 bg-cover bg-center transition-transform duration-500 hover:scale-[1.04]"
                style={`background-image: url("${getPostImage(post.data.thumbnail)}")`}></div>
              {postTags.length > 0 && (
                <span class="absolute top-3 left-3 bg-garnet text-white border-2 border-mahogany px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.07em]">
                  {postTags[0]}
                </span>
              )}
            </div>
            <div class="p-5 flex-1 flex flex-col gap-2.5">
              <h3 class="font-display text-[1.0625rem] font-bold text-charcoal dark:text-alabaster leading-[1.25] hover:text-garnet dark:hover:text-garnet-soft transition-colors">
                <a href={`/blog/${getSlugFromId(post.id)}`}>
                  {post.data.title}
                </a>
              </h3>
              <p class="text-[0.8125rem] text-ink-muted dark:text-ink-muted-dark leading-[1.65] flex-1 line-clamp-3">
                {post.data.description || 'Read the full story on Kenyan fashion and vintage culture.'}
              </p>
              <footer class="flex items-center justify-between mt-auto pt-3 border-t border-charcoal/10 dark:border-alabaster/10">
                <time class="text-xs text-ink-muted dark:text-ink-muted-dark" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <a href={`/blog/${getSlugFromId(post.id)}`} class="text-[0.8125rem] font-bold text-garnet inline-flex items-center gap-1 transition-[gap] duration-150 hover:gap-2 dark:text-garnet-soft">
                  Read story 
                  <span class="material-symbols-outlined" style="font-size:15px">north_east</span>
                </a>
              </footer>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="bg-charcoal border-t-2 border-charcoal py-16 pb-20" aria-labelledby="newsletter-heading">
    <div class="container-visha flex flex-col items-center text-center gap-5">
      <h2 id="newsletter-heading" class="text-[clamp(1.75rem,4vw,2.75rem)] font-extrabold text-alabaster">Stay Ahead of the Curve</h2>
      <p class="text-base text-alabaster/70 max-w-[40ch]">Join the weekly edit of Nairobi's best style — delivered to your inbox.</p>
      <form class="newsletter-form flex flex-col gap-2.5 max-w-[26rem] w-full" onsubmit="handleNewsletter(event)">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input id="newsletter-email" type="email" placeholder="Your email address" required class="input-brutalist flex-1" />
        <button type="submit" class="btn-alabaster">Subscribe</button>
      </form>
      <p id="newsletter-success" class="hidden items-center gap-2 font-bold text-alabaster">
        <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">check_circle</span>
        Welcome to the edit!
      </p>
      <p class="text-[11px] text-alabaster/40 uppercase tracking-widest font-semibold">No spam. Only curated inspiration.</p>
    </div>
  </section>

</Layout>

<script>
  // Newsletter subscription
  function handleNewsletter(e: Event) {
    e.preventDefault();
    const form = e.target as HTMLElement;
    form.classList.add('hidden');
    const success = document.getElementById('newsletter-success')!;
    success.classList.remove('hidden');
    success.style.display = 'flex';
  }
  (window as any).handleNewsletter = handleNewsletter;

  // Search & Filter functionality
  let activeTag = 'all';
  let searchQuery = '';

  const searchInput = document.getElementById('blog-search') as HTMLInputElement | null;
  const tagButtons = document.querySelectorAll('.tag-filter-btn');
  const postCards = document.querySelectorAll('.blog-post-card');
  const noResultsDiv = document.getElementById('no-results');
  const postsGrid = document.getElementById('posts-grid');
  const clearBtn = document.getElementById('clear-search-btn');
  const featuredSection = document.getElementById('featured-section');

  function updateFilters() {
    let visibleCount = 0;
    const isFiltering = searchQuery !== '' || activeTag !== 'all';

    // Show/hide featured post section on top
    if (featuredSection) {
      if (isFiltering) {
        featuredSection.style.display = 'none';
      } else {
        featuredSection.style.display = 'block';
      }
    }

    postCards.forEach((card) => {
      const element = card as HTMLElement;
      const searchContent = element.dataset.searchContent || '';
      const tags = JSON.parse(element.dataset.tags || '[]');
      const isFeatured = element.dataset.isFeatured === 'true';

      const matchesSearch = searchContent.includes(searchQuery);
      const matchesTag = activeTag === 'all' || tags.includes(activeTag);

      // If not filtering, we hide the featured article from the grid list.
      // If filtering, we display it if it matches the search/tag criteria.
      const shouldShow = matchesSearch && matchesTag && (isFiltering || !isFeatured);

      if (shouldShow) {
        element.style.setProperty('display', 'flex', 'important');
        visibleCount++;
      } else {
        element.style.setProperty('display', 'none', 'important');
      }
    });

    if (visibleCount === 0) {
      noResultsDiv?.classList.remove('hidden');
      postsGrid?.classList.add('hidden');
    } else {
      noResultsDiv?.classList.add('hidden');
      postsGrid?.classList.remove('hidden');
    }
  }

  // Search input listener
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    updateFilters();
  });

  // Tag button listeners
  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = (btn as HTMLElement).dataset.tag || 'all';

      // Update button styles to reflect selection state
      tagButtons.forEach((b) => {
        // Reset to inactive styles
        b.classList.remove('bg-garnet', 'text-white', 'border-charcoal', 'shadow-[2px_2px_0_#28231E]');
        b.classList.add('bg-white', 'text-charcoal', 'border-charcoal/20');
        
        // Dark mode inactive reset
        b.classList.remove('dark:bg-garnet-soft', 'dark:text-alabaster', 'dark:border-alabaster', 'dark:shadow-[2px_2px_0_#E6E1DE]');
        b.classList.add('dark:bg-card-dark', 'dark:text-alabaster', 'dark:border-warm-dusk');
      });

      // Apply active styles to clicked button
      activeTag = tag;
      btn.classList.remove('bg-white', 'text-charcoal', 'border-charcoal/20');
      btn.classList.add('bg-garnet', 'text-white', 'border-charcoal', 'shadow-[2px_2px_0_#28231E]');
      
      btn.classList.remove('dark:bg-card-dark', 'dark:border-warm-dusk');
      btn.classList.add('dark:bg-garnet-soft', 'dark:text-alabaster', 'dark:border-alabaster', 'dark:shadow-[2px_2px_0_#E6E1DE]');

      updateFilters();
    });
  });

  // Clear button listener
  clearBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    searchQuery = '';
    activeTag = 'all';

    tagButtons.forEach((b) => {
      b.classList.remove('bg-garnet', 'text-white', 'border-charcoal', 'shadow-[2px_2px_0_#28231E]');
      b.classList.add('bg-white', 'text-charcoal', 'border-charcoal/20');
      b.classList.remove('dark:bg-garnet-soft', 'dark:text-alabaster', 'dark:border-alabaster', 'dark:shadow-[2px_2px_0_#E6E1DE]');
      b.classList.add('dark:bg-card-dark', 'dark:text-alabaster', 'dark:border-warm-dusk');
    });

    const allBtn = document.querySelector('.tag-filter-btn[data-tag="all"]');
    if (allBtn) {
      allBtn.classList.remove('bg-white', 'text-charcoal', 'border-charcoal/20');
      allBtn.classList.add('bg-garnet', 'text-white', 'border-charcoal', 'shadow-[2px_2px_0_#28231E]');
      allBtn.classList.remove('dark:bg-card-dark', 'dark:border-warm-dusk');
      allBtn.classList.add('dark:bg-garnet-soft', 'dark:text-alabaster', 'dark:border-alabaster', 'dark:shadow-[2px_2px_0_#E6E1DE]');
    }

    updateFilters();
  });
</script>

<style>
  /* Newsletter form: flex row on wider screens */
  .newsletter-form:not(.hidden) { display: flex; }
  @media (min-width: 480px) { .newsletter-form:not(.hidden) { flex-direction: row; } }
</style>
