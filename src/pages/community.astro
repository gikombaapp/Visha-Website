---
// src/pages/community.astro
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<Layout
  title="Community — visha | Kenya's Thrift Movement"
  description="Join the visha community. Connect with curators, attend Nairobi events, and be part of Kenya's sustainable fashion movement."
  canonical="https://visha.app/community"
>

  <!-- Hero -->
  <section class="section-visha container-visha grid gap-12 items-center lg:grid-cols-2 lg:gap-20" aria-labelledby="community-heading">
    <div class="flex flex-col gap-6">
      <span class="tag tag-garnet">Community</span>
      <h1 id="community-heading" class="text-[clamp(2.2rem,5vw,3.75rem)] font-extrabold text-charcoal dark:text-alabaster">
        More than an app.<br />
        <span class="highlight">A movement.</span>
      </h1>
      <p class="text-base text-ink-muted dark:text-ink-muted-dark max-w-[44ch] leading-[1.7]">
        visha is home to Kenya's most vibrant community of sustainable fashion lovers. Whether you're a Gikomba vendor, a vintage hunter, or just getting started — you belong here.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/registration" class="btn-primary">Become a Member</a>
        <a href="/how" class="btn-ghost">How It Works</a>
      </div>
    </div>

    <div class="relative">
      <div class="absolute inset-[-0.75rem] bg-charcoal border-2 border-charcoal"></div>
      <div
        class="relative z-10 w-full aspect-[4/3] bg-cover bg-center border-2 border-charcoal shadow-[10px_10px_0_#000000]"
        style='background-image: url("/images/IMG_4987.webp")'
        role="img" aria-label="Nairobi thrift community event"
      ></div>
    </div>
  </section>

  <!-- Why join -->
  <section class="bg-alabaster border-y-2 border-charcoal py-16 dark:bg-warm-dusk" aria-labelledby="why-heading">
    <div class="container-visha">
      <header class="text-center mb-12">
        <h2 id="why-heading" class="section-title">Why join the community?</h2>
        <p class="section-body mx-auto">Inside visha, community is built in — not bolted on.</p>
      </header>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

        <article class="card-brutalist overflow-hidden">
          <div class="w-full aspect-video bg-cover bg-center border-b-2 border-charcoal dark:border-warm-dusk"
            style='background-image: url("/images/OIP-1582786169.webp")'
            aria-label="Nairobi community swap event" role="img"></div>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-garnet" style="font-size:20px">event_available</span>
              <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">In-App Events</h3>
            </div>
            <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Discover and RSVP to sip-and-swaps, Gikomba tours, and DIY upcycling workshops — all organised through the app.</p>
          </div>
        </article>

        <article class="card-brutalist overflow-hidden">
          <div class="w-full aspect-video bg-cover bg-position-[center_80%] border-b-2 border-charcoal dark:border-warm-dusk"
            style='background-image: url("/images/IMG_7108.webp")'
            aria-label="Seller spotlight feature" role="img"></div>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-garnet" style="font-size:20px">campaign</span>
              <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">Seller Spotlights</h3>
            </div>
            <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Get featured on the app's discover feed. We celebrate the most creative curators in our network every week.</p>
          </div>
        </article>

        <article class="card-brutalist overflow-hidden">
          <div class="w-full aspect-video bg-cover bg-position-[center_20%] border-b-2 border-charcoal dark:border-warm-dusk"
            style='background-image: url("/images/IMG_7736.webp")'
            aria-label="Ambassador program" role="img"></div>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="material-symbols-outlined text-garnet" style="font-size:20px">badge</span>
              <h3 class="font-display text-lg font-bold text-charcoal dark:text-alabaster">Ambassador Program</h3>
            </div>
            <p class="text-sm text-ink-muted dark:text-ink-muted-dark leading-[1.65]">Top sellers earn Ambassador status — exclusive badges, early access to new features, and networking opportunities.</p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Waitlist -->
  <section class="bg-charcoal border-t-2 border-charcoal py-20" aria-labelledby="waitlist-heading">
    <div class="container-visha flex flex-col items-center text-center gap-5">
      <div class="w-14 h-14 bg-garnet border-2 border-mahogany flex items-center justify-center text-white shadow-[3px_3px_0_#000000]">
        <span class="material-symbols-outlined" style="font-size:1.5rem">mail</span>
      </div>
      <h2 id="waitlist-heading" class="text-[clamp(1.75rem,4vw,2.75rem)] font-extrabold text-alabaster uppercase">Join the Kenyan Waitlist</h2>
      <p class="text-base text-alabaster/70 max-w-[44ch] leading-[1.65]">Get on the early access list and receive a founding member badge when we launch in Nairobi.</p>
      <div class="max-w-[28rem] w-full [&_.waitlist-success]:text-alabaster">
        <WaitlistForm id="community" dark={true} placeholder="YOUR EMAIL ADDRESS" btnLabel="Join Now" />
      </div>
      <p class="text-xs text-alabaster/50 font-semibold uppercase tracking-[0.08em]">No spam. Just launch updates.</p>
    </div>
  </section>

</Layout>
