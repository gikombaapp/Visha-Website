---
// src/pages/community.astro
import Layout from '../layouts/Layout.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
---

<Layout
  title="Community — visha | Kenya's Thrift Movement"
  description="Join the visha community. Connect with curators, attend Nairobi events, and be part of Kenya's sustainable fashion movement."
  canonical="https://visha.app/community"
>

  <!-- Hero -->
  <section class="section container community-hero" aria-labelledby="community-heading">
    <div class="hero-text">
      <span class="tag tag-garnet">Community</span>
      <h1 id="community-heading" class="hero-h1">
        More than an app.<br />
        <span class="hero-hl">A movement.</span>
      </h1>
      <p class="hero-body">
        visha is home to Kenya's most vibrant community of sustainable fashion lovers. Whether you're a Gikomba vendor, a vintage hunter, or just getting started — you belong here.
      </p>
      <div class="hero-actions">
        <a href="/registration" class="btn btn-primary">Become a Member</a>
        <a href="/how" class="btn btn-ghost">How It Works</a>
      </div>
    </div>

    <div class="hero-img-wrap">
      <div class="hero-img-bg"></div>
      <div class="hero-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuACVm0M3bynGdI2VYO9pmoYqJGrkCH-UrJoChYBqUtT8I_78Bo2yrvh9r0SmNy788EH89qKtdd1mp6wL-A81LeQRt49UiNteQnZAxtOJK5yHjc9xxhLwBm-xoYUwbCr_zwLxs3CPx1hnHv6xBgo8p6wsdlVuGyhFqXWgo1dXYAikb-4EcmQHdBJ-YlHAODFbdCyAch2FMTR4pDciSsEgVsjRtCg_2QiexMkJxqxR-3u1E9jg1hUQV-OBkmDRiaCcxLlPNHJHR55UpI")' role="img" aria-label="Nairobi thrift community event"></div>
    </div>
  </section>

  <!-- Why join -->
  <section class="why-section" aria-labelledby="why-heading">
    <div class="container">
      <header class="why-header">
        <h2 id="why-heading" class="section-title">Why join the community?</h2>
        <p class="section-body">Inside visha, community is built in — not bolted on.</p>
      </header>
      <div class="why-grid">

        <article class="card why-card">
          <div class="why-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuCqjNi7Ikfex46jD91fezFlzGJRetYARJAF00W5ewHs1Mjx5r7jImeqnTvINP-CKnfD3CK9UBa8gtMtv5sfHRDvkOEC6aNKnJiKzd5_Uek5qd2h3HVy_NgUQyVahAEUEHQPeaCW4bTWCJMyTb7lA3zqm09cWVS10bY4ND3cT5aEpAhbts0I3mTpgEw-lyXLvyw947Do9zbbgFK6uwc7J6SL-zrQm1x4-ZrvAMmUlvPDYReyzlSIMtFXoJ6Si8Cd1tnJ5VIBITSyxNk")' aria-label="Nairobi community swap event" role="img"></div>
          <div class="why-card-body">
            <div class="why-icon-row">
              <span class="material-symbols-outlined" style="color:var(--garnet)">event_available</span>
              <h3 class="why-title">In-App Events</h3>
            </div>
            <p class="why-body">Discover and RSVP to sip-and-swaps, Gikomba tours, and DIY upcycling workshops — all organised through the app.</p>
          </div>
        </article>

        <article class="card why-card">
          <div class="why-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBBGyQ4q5vH6clH9W0UFBJxBvMMJTOCQkSI5ILtCDY48E-FsBLPZIbCvwtCOHSTMXK_aGx3JFFWqYFA65JW__6TvD40gD8aMK4rmvKaJ-LxE7IbJmKVNmXs6OsylPkZhajHC25lqflImbFy6kOj-DCEKPhcuh5ufKuMm55ppLzIcqvcub8yq5yADO_TV-BOsokH7_avVA3NsU1o6eGho2T7JIIvg4FUB1MSMRRBImIubVvB-qhp318UtZ0VAAP8Tn19o0sW1o3dmzc")' aria-label="Seller spotlight feature" role="img"></div>
          <div class="why-card-body">
            <div class="why-icon-row">
              <span class="material-symbols-outlined" style="color:var(--garnet)">campaign</span>
              <h3 class="why-title">Seller Spotlights</h3>
            </div>
            <p class="why-body">Get featured on the app's discover feed. We celebrate the most creative curators in our network every week.</p>
          </div>
        </article>

        <article class="card why-card">
          <div class="why-img" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuA6SzHP979-2PGP49rNAovVMsPUcUyiuu2g4KeVs_H047DI3R-H6XHk0jYkAWwWMU9y9I_BjR59zC_D1XPgqFt5IE2Rs-TUM0bRPRAsENR6uJmgcz9WEX0lxQ5qdz_JZcVKIE4OK7uuOyXmcXBSZAR6IUjc907BrMq0laq5fpzigHZx14SkcEI6CwCFCQspme-98WLO488oQyC02-Po9DkfFKxG3iEsKwptBBrNQAc6ytMOx19Z5afdLZKS8R-XUB3zh9WpSu1ZL2Q")' aria-label="Ambassador program" role="img"></div>
          <div class="why-card-body">
            <div class="why-icon-row">
              <span class="material-symbols-outlined" style="color:var(--garnet)">badge</span>
              <h3 class="why-title">Ambassador Program</h3>
            </div>
            <p class="why-body">Top sellers earn Ambassador status — exclusive badges, early access to new features, and networking opportunities.</p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Featured curator -->
  <section class="section container curator-section" aria-labelledby="curator-heading">
    <div class="curator-left">
      <h2 id="curator-heading" class="section-title">
        This month's<br />
        <span style="background:var(--garnet); color:var(--white); padding:0 0.25em">featured curator</span>
      </h2>
      <blockquote class="card curator-quote">
        <p class="quote-text">"Thrifting in Nairobi isn't just about cheap clothes — it's about preserving stories. visha made it easy to find my tribe."</p>
        <footer class="quote-footer">
          <div class="quote-avatar">
            <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuD06cWdWySFrPMQGciraQ7pbJ9bm5EFWDzSEwrMxoBBVE_A9v4Y7OiHUGvLtQoUykm5aijXsmiWhWWg5rXTWxuER3pPGNjbJE9rC7MJEg1JEOI0N-2r70PCrXTl-gR5KNAqEnlW89d_MHWAmPozFfy1edfF481buJIfQMwhBz-1KUnnQuek_s3bVFAw_FitGREqX74hQWsRcF3_QKFiLqr_mFPRSKfy8YJwZ1vdGrxQwOMLj3Gixc0_JRDQ8QzAxxjxisf6tBLLJIA"
              alt="Sarah Jenkins" class="curator-avatar-img" loading="lazy" />
          </div>
          <div>
            <cite class="quote-name">Sarah Jenkins</cite>
            <p class="quote-role">Vintage Collector · on visha since 2023</p>
          </div>
        </footer>
      </blockquote>
    </div>

    <div class="curator-images">
      <div class="curator-img curator-img--1" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBHsYJ9Qa7ARi16yjsu3YkoArjLkol2Vc3J7xrfOD_Z-LwfIRuE6TULzzADEwgW4jdNvInFvY4_XmZsfwEmQiTPkbTBRoT5nHi8dMGkOZ1_BJLl1uyk-SzsaMMnVhBSt3eVV3wGlNg-XwIsKvbtmBf1ozoqwKdPrfgFpeH30O3I8ekotZPDHL8Azl6DyGa8dA-9s9wHkpdwYs66aGuGA9kF2opxWJoV4GeF2Ttw-feK8EpriJa0xgJqb5BLk0KD3Jeuqn7ZRyRScnk")' role="img" aria-label="Curator listing"></div>
      <div class="curator-img curator-img--2" style='background-image: url("https://lh3.googleusercontent.com/aida-public/AB6AXuBW-Pgug-8HEmVajHNsXIxHmNxjfV8lvsBMN4DR7n69CSQX0I7mYxRQPaepsD42cSCV2UGJZbzhiKiQ6b7vvO45fUVuJx5jPexlx9VRFh3g5Oizx4HomfmcBANWWKChfg7_A3psl3uzvfu_2pkcNXXdES7uFSs0nqBU1OVp8_5eVf1keAdEmF-pKFVufJlt4agUIr3biRHTuAuRyf-Noj0g8-HOz4mTheN7UvpeylSyyxUe4Wzmps9B4J814sJyn_KYL0ygzE0E3Bc")' role="img" aria-label="Curator listing"></div>
    </div>
  </section>

  <!-- Waitlist -->
  <section class="waitlist-section" aria-labelledby="waitlist-heading">
    <div class="container waitlist-inner">
      <div class="waitlist-icon">
        <span class="material-symbols-outlined">mail</span>
      </div>
      <h2 id="waitlist-heading" class="waitlist-title">Join the Kenyan Waitlist</h2>
      <p class="waitlist-body">Get on the early access list and receive a founding member badge when we launch in Nairobi.</p>
      <WaitlistForm id="community" dark={true} placeholder="YOUR EMAIL ADDRESS" btnLabel="Join Now" />
      <p class="waitlist-note">No spam. Just launch updates.</p>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .community-hero { display: grid; gap: 3rem; align-items: center; }
  @media (min-width: 1024px) { .community-hero { grid-template-columns: 1fr 1fr; gap: 5rem; } }

  .hero-h1 { font-size: clamp(2.2rem, 5vw, 3.75rem); font-weight: 800; color: var(--charcoal); }
  body.dark .hero-h1 { color: var(--alabaster); }
  .hero-hl { background: var(--garnet); color: var(--white); padding: 0 0.25em; }
  .hero-body { font-size: 1rem; color: var(--color-ink-muted); max-width: 44ch; line-height: 1.7; }
  body.dark .hero-body { color: var(--color-ink-muted-dark); }
  .hero-text { display: flex; flex-direction: column; gap: 1.5rem; }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }

  .hero-img-wrap { position: relative; }
  .hero-img-bg {
    position: absolute; inset: -0.75rem;
    background: var(--charcoal);
    border: 2px solid var(--charcoal);
  }
  .hero-img {
    position: relative; z-index: 1;
    width: 100%; aspect-ratio: 4/3;
    background-size: cover; background-position: center;
    border: 2px solid var(--charcoal);
    box-shadow: 10px 10px 0 var(--charcoal);
  }

  /* Why */
  .why-section { background: var(--alabaster); border-top: 2px solid var(--charcoal); border-bottom: 2px solid var(--charcoal); padding-block: 4rem; }
  body.dark .why-section { background: var(--charcoal-soft); }
  .why-header { text-align: center; margin-bottom: 3rem; }
  .why-grid { display: grid; gap: 1.5rem; }
  @media (min-width: 640px)  { .why-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .why-grid { grid-template-columns: repeat(3, 1fr); } }

  .why-card { overflow: hidden; }
  .why-img { width: 100%; aspect-ratio: 16/9; background-size: cover; background-position: center; border-bottom: 2px solid var(--charcoal); }
  .why-card-body { padding: 1.25rem; }
  .why-icon-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
  .why-icon-row .material-symbols-outlined { font-size: 20px; }
  .why-title { font-family: var(--font-display); font-size: 1.125rem; font-weight: 700; color: var(--charcoal); }
  body.dark .why-title { color: var(--alabaster); }
  .why-body { font-size: 0.875rem; color: var(--color-ink-muted); line-height: 1.65; }
  body.dark .why-body { color: var(--color-ink-muted-dark); }

  /* Curator */
  .curator-section { display: flex; flex-direction: column; gap: 3rem; }
  @media (min-width: 768px) { .curator-section { flex-direction: row; align-items: center; gap: 4rem; } }

  .curator-left { flex: 1; display: flex; flex-direction: column; gap: 1.5rem; }
  .curator-quote { padding: 1.75rem; }
  .quote-text { font-family: var(--font-display); font-size: 1.125rem; font-style: italic; color: var(--garnet); line-height: 1.5; margin-bottom: 1.25rem; }
  .quote-footer { display: flex; align-items: center; gap: 0.875rem; }
  .quote-avatar { width: 3rem; height: 3rem; border: 2px solid var(--charcoal); overflow: hidden; flex-shrink: 0; }
  .curator-avatar-img { width: 100%; height: 100%; object-fit: cover; }
  .quote-name { font-weight: 700; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--charcoal); display: block; }
  body.dark .quote-name { color: var(--alabaster); }
  .quote-role { font-size: 0.75rem; color: var(--color-ink-muted); }
  body.dark .quote-role { color: var(--color-ink-muted-dark); }

  .curator-images { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .curator-img { aspect-ratio: 1; background-size: cover; background-position: center; border: 2px solid var(--charcoal); box-shadow: var(--shadow-md); }
  .curator-img--2 { margin-top: 2.5rem; }

  /* Waitlist */
  .waitlist-section {
    background: var(--charcoal);
    border-top: 2px solid var(--charcoal);
    padding-block: 5rem;
  }
  .waitlist-inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 1.25rem; }
  .waitlist-icon {
    width: 3.5rem; height: 3.5rem;
    background: var(--garnet); border: 2px solid var(--garnet-dark);
    display: flex; align-items: center; justify-content: center; color: var(--white);
    box-shadow: var(--shadow-sm);
  }
  .waitlist-icon .material-symbols-outlined { font-size: 1.5rem; }
  .waitlist-title { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; color: var(--alabaster); text-transform: uppercase; }
  .waitlist-body { font-size: 1rem; color: rgba(230,225,222,0.7); max-width: 44ch; line-height: 1.65; }
  .waitlist-note { font-size: 0.75rem; color: rgba(230,225,222,0.5); font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; }
  .waitlist-inner :global(.waitlist-wrap) { max-width: 28rem; width: 100%; }
  .waitlist-inner :global(.waitlist-success) { color: var(--alabaster); }

  /* Shared */
  .section-title { font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; color: var(--charcoal); margin-bottom: 0.75rem; }
  body.dark .section-title { color: var(--alabaster); }
  .section-body { font-size: 1rem; color: var(--color-ink-muted); max-width: 50ch; }
  body.dark .section-body { color: var(--color-ink-muted-dark); }
</style>
