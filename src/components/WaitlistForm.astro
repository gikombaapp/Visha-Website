---
// src/components/WaitlistForm.astro
interface Props {
  id: string;           // unique id per page (for the success message)
  placeholder?: string;
  btnLabel?: string;
  dark?: boolean;       // true = white input for dark backgrounds
}

const {
  id,
  placeholder = 'Your email address',
  btnLabel = 'Join Waitlist',
  dark = false,
} = Astro.props;
---

<div class="waitlist-wrap" data-waitlist-id={id}>
  <form class={`waitlist-form ${dark ? 'waitlist-form--dark' : ''}`} novalidate>
    <label for={`waitlist-${id}`} class="sr-only">Email address</label>
    <input
      id={`waitlist-${id}`}
      type="email"
      required
      placeholder={placeholder}
      class={`input waitlist-input ${dark ? 'waitlist-input--dark' : ''}`}
    />
    <button type="submit" class={`btn ${dark ? 'btn-alabaster' : 'btn-primary'}`}>
      {btnLabel}
    </button>
  </form>
  <p class="waitlist-success hidden" id={`waitlist-success-${id}`}>
    <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">check_circle</span>
    You're on the list — we'll be in touch!
  </p>
</div>

<script>
  document.querySelectorAll('[data-waitlist-id]').forEach((wrap) => {
    const id = (wrap as HTMLElement).dataset.waitlistId!;
    const form = wrap.querySelector('form')!;
    const success = document.getElementById(`waitlist-success-${id}`)!;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.classList.add('hidden');
      success.classList.remove('hidden');
    });
  });
</script>

<style>
  .waitlist-wrap { width: 100%; }
  .waitlist-form {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    width: 100%;
  }
  @media (min-width: 480px) { .waitlist-form { flex-direction: row; } }

  .waitlist-input { flex: 1; }

  .waitlist-input--dark {
    background: var(--white);
    border-color: var(--charcoal);
    color: var(--charcoal);
  }

  .waitlist-success {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--garnet);
    padding: 0.75rem 0;
  }
  .waitlist-success.hidden { display: none; }

  .waitlist-form.hidden { display: none; }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
