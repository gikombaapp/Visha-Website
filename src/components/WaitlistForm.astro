---
// src/components/WaitlistForm.astro
interface Props {
  id: string;           // unique id per page (for the success message)
  placeholder?: string;
  btnLabel?: string;
  dark?: boolean;       // true = white input for dark backgrounds
}

const {
  id,
  placeholder = 'Your email address',
  btnLabel = 'Join Waitlist',
  dark = false,
} = Astro.props;
---

<div class="w-full" data-waitlist-id={id}>
  <form class={`waitlist-form w-full flex flex-col gap-2.5 ${dark ? 'waitlist-form--dark' : ''}`} novalidate>
    <label for={`waitlist-${id}`} class="sr-only">Email address</label>
    <input
      id={`waitlist-${id}`}
      type="email"
      required
      placeholder={placeholder}
      class={`flex-1 ${dark ? 'input-brutalist bg-white border-charcoal text-charcoal placeholder:text-ink-muted' : 'input-brutalist'}`}
    />
    <button type="submit" class={dark ? 'btn-alabaster' : 'btn-primary'}>
      {btnLabel}
    </button>
  </form>
  <p class="waitlist-success hidden items-center gap-2 font-bold text-[0.9rem] text-garnet py-3" id={`waitlist-success-${id}`}>
    <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">check_circle</span>
    You're on the list — we'll be in touch!
  </p>
</div>

<script>
  document.querySelectorAll('[data-waitlist-id]').forEach((wrap) => {
    const id = (wrap as HTMLElement).dataset.waitlistId!;
    const form = wrap.querySelector('form')!;
    const success = document.getElementById(`waitlist-success-${id}`)!;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.classList.add('hidden');
      success.classList.remove('hidden');
    });
  });
</script>

<style>
  /* JS toggles .hidden on these; flex must win when visible */
  .waitlist-form:not(.hidden) { display: flex; }
  @media (min-width: 480px) { .waitlist-form:not(.hidden) { flex-direction: row; } }
  .waitlist-success:not(.hidden) { display: flex; }
</style>
