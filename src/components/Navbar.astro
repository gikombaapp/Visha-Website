---
// src/components/Navbar.astro
const links = [
  { label: 'Home',         href: '/' },
  { label: 'How It Works', href: '/how' },
  { label: 'Community',    href: '/community' },
  { label: 'Blog',         href: '/blog' },
  { label: 'Support',      href: '/support' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  class="sticky top-0 z-50 bg-parchment border-b-2 border-charcoal transition-colors duration-200 dark:bg-charcoal dark:border-warm-dusk"
  id="site-header"
>
  <div class="container-visha flex items-center justify-between gap-4 py-3">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="visha home">
      <div class="w-8 h-8 bg-garnet border-2 border-charcoal flex items-center justify-center text-alabaster shrink-0">
        <span class="material-symbols-outlined" style="font-size:16px">local_mall</span>
      </div>
      <div class="font-display font-extrabold text-[1.1rem] text-charcoal leading-none dark:text-alabaster">
        visha
        <span class="text-[0.6rem] font-normal tracking-[0.08em] uppercase text-ink-muted block mt-px dark:text-ink-muted-dark">for the collective</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-7" aria-label="Main navigation">
      {links.map(({ label, href }) => (
        <a
          href={href}
          class={`text-sm font-semibold pb-0.5 border-b-2 transition-colors duration-150 hover:text-garnet hover:border-garnet dark:hover:text-alabaster-dark ${
            isActive(href)
              ? 'text-garnet border-garnet dark:text-alabaster dark:border-alabaster'
              : 'text-charcoal border-transparent dark:text-alabaster'
          }`}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
      
      <!-- Admin/Author Login Link - Always visible on desktop -->
      <a
        href="/admin/login"
        class="text-sm font-semibold pb-0.5 border-b-2 border-transparent text-ink-muted hover:text-garnet hover:border-garnet transition-colors duration-150 dark:text-ink-muted-dark dark:hover:text-alabaster"
      >
        Author Login
      </a>
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-2">
      <!-- Dark mode toggle -->
      <button
        id="dark-toggle"
        class="w-9 h-9 border-2 border-charcoal bg-transparent text-charcoal flex items-center justify-center cursor-pointer transition-colors duration-150 hover:bg-garnet hover:text-white hover:border-garnet dark:border-warm-dusk dark:text-alabaster"
        aria-label="Toggle dark mode"
      >
        <span class="material-symbols-outlined dark-icon" style="font-size:18px">dark_mode</span>
      </button>

      <!-- Join CTA -->
      <a href="/registration" class="btn-primary hidden sm:inline-flex">
        Join Waitlist
      </a>

      <!-- Hamburger -->
      <button
        id="menu-btn"
        class="w-9 h-9 border-2 border-charcoal bg-transparent text-charcoal flex items-center justify-center cursor-pointer lg:hidden transition-colors duration-150 hover:bg-garnet hover:text-white hover:border-garnet dark:border-warm-dusk dark:text-alabaster"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="material-symbols-outlined" id="hamburger-icon" style="font-size:18px">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <nav
    id="mobile-menu"
    class="hidden border-t-2 border-charcoal bg-parchment px-5 pb-4 dark:bg-charcoal dark:border-warm-dusk"
    aria-label="Mobile navigation"
  >
    {links.map(({ label, href }) => (
      <a
        href={href}
        class={`block text-base font-semibold py-3.5 border-b border-charcoal/10 transition-colors duration-150 dark:border-alabaster/10 hover:text-garnet ${
          isActive(href)
            ? 'text-garnet dark:text-alabaster-dark'
            : 'text-charcoal dark:text-alabaster'
        }`}
        aria-current={isActive(href) ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
    
    <!-- Admin/Author Login Link in mobile menu -->
    <a
      href="/admin/login"
      class="block text-base font-semibold py-3.5 border-b border-charcoal/10 text-ink-muted hover:text-garnet transition-colors duration-150 dark:border-alabaster/10 dark:text-ink-muted-dark dark:hover:text-alabaster"
    >
      Author Login
    </a>
    
    <a href="/registration" class="btn-primary mt-3 justify-center">
      Join Waitlist
      <span class="material-symbols-outlined" style="font-size:16px">arrow_forward</span>
    </a>
  </nav>
</header>

<style>
  /* Mobile menu is flex-col when visible; .hidden (display:none) overrides when closed */
  #mobile-menu:not(.hidden) { display: flex; flex-direction: column; }
</style>