---
// src/components/Footer.astro
---

<footer class="site-footer">
  <div class="container footer-inner">

    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="visha home">
        <div class="footer-logo-mark">
          <span class="material-symbols-outlined">local_mall</span>
        </div>
        <span class="footer-logo-text">visha</span>
      </a>
      <p class="footer-tagline">
        For the collective. Pre-loved fashion in Kenya — M-Pesa ready, community verified.
      </p>
    </div>

    <nav class="footer-nav" aria-label="App links">
      <h3 class="footer-nav-title">App</h3>
      <ul>
        <li><a href="/how">How It Works</a></li>
        <li><a href="/registration">Join Waitlist</a></li>
        <li><a href="/community">Community</a></li>
        <li><a href="/blog">Fashion Blog</a></li>
      </ul>
    </nav>

    <nav class="footer-nav" aria-label="Support links">
      <h3 class="footer-nav-title">Help</h3>
      <ul>
        <li><a href="/support">Support</a></li>
        <li><a href="/support#faq">FAQ</a></li>
        <li><a href="#">Privacy Policy</a></li>
        <li><a href="#">Terms of Service</a></li>
      </ul>
    </nav>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© 2024 visha — for the collective. Built in Nairobi.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 2px solid var(--charcoal);
    background: var(--white);
    margin-top: auto;
  }
  body.dark .site-footer {
    background: var(--color-surface-card-dark);
    border-color: var(--charcoal-soft);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    padding-block: 3rem;
  }
  @media (min-width: 768px) {
    .footer-inner { grid-template-columns: 2fr 1fr 1fr; }
  }

  .footer-brand { grid-column: 1 / -1; }
  @media (min-width: 768px) { .footer-brand { grid-column: auto; } }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .footer-logo-mark {
    width: 1.75rem; height: 1.75rem;
    background: var(--garnet);
    border: 2px solid var(--charcoal);
    display: flex; align-items: center; justify-content: center;
    color: var(--white);
  }
  .footer-logo-mark .material-symbols-outlined { font-size: 14px; }
  .footer-logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
    color: var(--charcoal);
  }
  body.dark .footer-logo-text { color: var(--alabaster); }

  .footer-tagline {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
    max-width: 26ch;
  }
  body.dark .footer-tagline { color: var(--color-ink-muted-dark); }

  .footer-nav-title {
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--charcoal);
    margin-bottom: 1rem;
  }
  body.dark .footer-nav-title { color: var(--alabaster); }

  .footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .footer-nav a {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    transition: color 0.15s;
  }
  body.dark .footer-nav a { color: var(--color-ink-muted-dark); }
  .footer-nav a:hover { color: var(--garnet); }
  body.dark .footer-nav a:hover { color: var(--alabaster); }

  .footer-bottom {
    border-top: 1px solid rgba(37,41,28,0.15);
    padding-block: 1.25rem;
  }
  body.dark .footer-bottom { border-color: rgba(230,225,222,0.1); }
  .footer-bottom-inner {
    display: flex;
    justify-content: center;
  }
  .footer-bottom p {
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    text-align: center;
  }
  body.dark .footer-bottom p { color: var(--color-ink-muted-dark); }
</style>
